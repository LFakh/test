e\": {\n      \"version\": \"0.1.0\",\n      \"resolved\": \"https://registry.npmjs.org/yocto-queue/-/yocto-queue-0.1.0.tgz\",\n      \"integrity\": \"sha512-rVksvsnNCdJ/ohGc6xgPwyN8eheCxsiLM8mxuE/t/mOVqJewPuO1miLpTHQiRgTKCLexL4MeAFVagts7HmNZ2Q==\",\n      \"dev\": true,\n      \"license\": \"MIT\",\n      \"engines\": {\n        \"node\": \"\u003e=10\"\n      },\n      \"funding\": {\n        \"url\": \"https://github.com/sponsors/sindresorhus\"\n      }\n    },\n    \"node_modules/zod\": {\n      \"version\": \"3.25.48\",\n      \"resolved\": \"https://registry.npmjs.org/zod/-/zod-3.25.48.tgz\",\n      \"integrity\": \"sha512-0X1mz8FtgEIvaxGjdIImYpZEaZMrund9pGXm3M6vM7Reba0e2eI71KPjSCGXBfwKDPwPoywf6waUKc3/tFvX2Q==\",\n      \"dev\": true,\n      \"license\": \"MIT\",\n      \"funding\": {\n        \"url\": \"https://github.com/sponsors/colinhacks\"\n      }\n    },\n    \"node_modules/zwitch\": {\n      \"version\": \"2.0.4\",\n      \"resolved\": \"https://registry.npmjs.org/zwitch/-/zwitch-2.0.4.tgz\",\n      \"integrity\": \"sha512-bXE4cR/kVZhKZX/RjPEflHaKVhUVl85noU3v6b8apfQEc1x4A+zBxjZ4lN8LqGd6WZ3dl98pY4o717VFmoPp+A==\",\n      \"dev\": true,\n      \"license\": \"MIT\",\n      \"funding\": {\n        \"type\": \"github\",\n        \"url\": \"https://github.com/sponsors/wooorm\"\n      }\n    }\n  }\n}\n","fullPath":"package-lock.json","isBinary":false,"lastModified":1771364966261},"src/entry.dev.tsx":{"name":"entry.dev.tsx","type":"file","contents":"/*\n * WHAT IS THIS FILE?\n *\n * Development entry point using only client-side modules:\n * - Do not use this mode in production!\n * - No SSR\n * - No portion of the application is pre-rendered on the server.\n * - All of the application is running eagerly in the browser.\n * - More code is transferred to the browser than in SSR mode.\n * - Optimizer/Serialization/Deserialization code is not exercised!\n */\nimport { render } from \"@builder.io/qwik\";\nimport Root from \"./root\";\n\nrender(document, \u003cRoot /\u003e);","fullPath":"src/entry.dev.tsx","isBinary":false,"lastModified":1771364966261},"src/entry.ssr.tsx":{"name":"entry.ssr.tsx","type":"file","contents":"/**\n * WHAT IS THIS FILE?\n *\n * SSR entry point, in all cases the application is render outside the browser, this\n * entry point will be the common one.\n *\n * - Server (express, cloudflare...)\n * - npm run start\n * - npm run preview\n * - npm run build\n *\n */\nimport {\n  renderToStream,\n  type RenderToStreamOptions,\n} from \"@builder.io/qwik/server\";\nimport { manifest } from \"@qwik-client-manifest\";\nimport Root from \"./root\";\n\nexport default function (opts: RenderToStreamOptions) {\n  return renderToStream(\u003cRoot /\u003e, {\n    manifest,\n    ...opts,\n    // Use container attributes to set attributes on the html tag.\n    containerAttributes: {\n      lang: \"en-us\",\n      ...opts.containerAttributes,\n    },\n  });\n}","fullPath":"src/entry.ssr.tsx","isBinary":false,"lastModified":1771364966261},"src/routes/movies":{"name":"movies","type":"folder","fullPath":"src/routes/movies","lastModified":1771364966261},"src/routes/search":{"name":"search","type":"folder","fullPath":"src/routes/search","lastModified":1771364966261},"public/favicon.ico":{"name":"favicon.ico","type":"file","contents":"","fullPath":"public/favicon.ico","isBinary":true,"lastModified":1771364966261},"src/components/row":{"name":"row","type":"folder","fullPath":"src/components/row","lastModified":1771364966261},"src/routes/my-list":{"name":"my-list","type":"folder","fullPath":"src/routes/my-list","lastModified":1771364966261},"src/routes/tv/[id]":{"name":"[id]","type":"folder","fullPath":"src/routes/tv/[id]","lastModified":1771364966261},"src/types/index.ts":{"name":"index.ts","type":"file","contents":"export interface Movie {\n  id: number;\n  title?: string;\n  name?: string;\n  original_name?: string;\n  backdrop_path?: string;\n  poster_path?: string;\n  overview?: string;\n  vote_average?: number;\n  release_date?: string;\n  first_air_date?: string;\n  genre_ids: number[];\n  media_type?: string;\n}\n\nexport interface Genre {\n  id: number;\n  name: string;\n}\n\nexport interface MovieDetails extends Movie {\n  genres: Genre[];\n  runtime: number;\n  budget: number;\n  revenue: number;\n  homepage: string;\n  status: string;\n  tagline: string;\n  videos: {\n    results: Video[];\n  };\n  credits: {\n    cast: Cast[];\n    crew: Crew[];\n  };\n  similar: {\n    results: Movie[];\n  };\n}\n\nexport interface TvShowDetails extends Movie {\n  genres: Genre[];\n  number_of_seasons: number;\n  number_of_episodes: number;\n  episode_run_time: number[];\n  status: string;\n  tagline: string;\n  created_by: Creator[];\n  videos: {\n    results: Video[];\n  };\n  credits: {\n    cast: Cast[];\n    crew: Crew[];\n  };\n  similar: {\n    results: Movie[];\n  };\n}\n\nexport interface Video {\n  id: string;\n  key: string;\n  name: string;\n  site: string;\n  type: string;\n}\n\nexport interface Cast {\n  id: number;\n  name: string;\n  character: string;\n  profile_path: string;\n}\n\nexport interface Crew {\n  id: number;\n  name: string;\n  job: string;\n  department: string;\n  profile_path: string;\n}\n\nexport interface Creator {\n  id: number;\n  name: string;\n  profile_path: string;\n}","fullPath":"src/types/index.ts","isBinary":false,"lastModified":1771364966261},"src/routes/tv-shows":{"name":"tv-shows","type":"folder","fullPath":"src/routes/tv-shows","lastModified":1771364966261},"public/user-icon.png":{"name":"user-icon.png","type":"file","contents":"","fullPath":"public/user-icon.png","isBinary":true,"lastModified":1771364966261},"src/routes/index.tsx":{"name":"index.tsx","type":"file","contents":"import { component$, useSignal, useTask$ } from \"@builder.io/qwik\";\nimport type { DocumentHead } from \"@builder.io/qwik-city\";\nimport { Navbar } from \"~/components/navbar/navbar\";\nimport { Banner } from \"~/components/banner/banner\";\nimport { Row } from \"~/components/row/row\";\nimport type { Movie } from \"~/types\";\nimport styles from \"./index.module.css\";\n\nconst API_KEY = import.meta.env.VITE_TMDB_API_KEY;\nconst BASE_URL = \"https://api.themoviedb.org/3\";\n\nexport default component$(() =\u003e {\n  const lotsofflexOriginals = useSignal\u003cMovie[]\u003e([]);\n  const trending = useSignal\u003cMovie[]\u003e([]);\n  const topRated = useSignal\u003cMovie[]\u003e([]);\n  const actionMovies = useSignal\u003cMovie[]\u003e([]);\n  const comedyMovies = useSignal\u003cMovie[]\u003e([]);\n  const horrorMovies = useSignal\u003cMovie[]\u003e([]);\n  const romanceMovies = useSignal\u003cMovie[]\u003e([]);\n  const documentaries = useSignal\u003cMovie[]\u003e([]);\n  const isLoading = useSignal(true);\n\n  useTask$(async () =\u003e {\n    try {\n      const [\n        originalsRes,\n        trendingRes,\n        topRatedRes,\n        actionRes,\n        comedyRes,\n        horrorRes,\n        romanceRes,\n        docsRes,\n      ] = await Promise.all([\n        fetch(`${BASE_URL}/discover/tv?api_key=${API_KEY}\u0026with_networks=213`),\n        fetch(`${BASE_URL}/trending/all/week?api_key=${API_KEY}\u0026language=en-US`),\n        fetch(`${BASE_URL}/movie/top_rated?api_key=${API_KEY}\u0026language=en-US`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=28`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=35`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=27`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=10749`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=99`),\n      ]);\n\n      const [\n        originalsData,\n        trendingData,\n        topRatedData,\n        actionData,\n        comedyData,\n        horrorData,\n        romanceData,\n        docsData,\n      ] = await Promise.all([\n        originalsRes.json(),\n        trendingRes.json(),\n        topRatedRes.json(),\n        actionRes.json(),\n        comedyRes.json(),\n        horrorRes.json(),\n        romanceRes.json(),\n        docsRes.json(),\n      ]);\n\n      lotsofflexOriginals.value = originalsData.results || [];\n      trending.value = trendingData.results || [];\n      topRated.value = topRatedData.results || [];\n      actionMovies.value = actionData.results || [];\n      comedyMovies.value = comedyData.results || [];\n      horrorMovies.value = horrorData.results || [];\n      romanceMovies.value = romanceData.results || [];\n      documentaries.value = docsData.results || [];\n      isLoading.value = false;\n    } catch (error) {\n      console.error(\"Error fetching data:\", error);\n      isLoading.value = false;\n    }\n  });\n\n  return (\n    \u003cdiv class={styles.container}\u003e\n      \u003cNavbar /\u003e\n      \u003cmain class={styles.main}\u003e\n        {isLoading.value ? (\n          \u003cdiv class={styles.loadingContainer}\u003e\n            \u003cdiv class={styles.loadingContent}\u003e\n              \u003cimg src=\"/lotsoflex-logo.png\" alt=\"Lotsoflex\" width={120} height={32} class={styles.loadingLogo} /\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n        ) : (\n          \u003c\u003e\n            \u003cBanner movies={lotsofflexOriginals.value} /\u003e\n            \u003csection class={styles.sectionsContainer}\u003e\n              \u003cRow title=\"Trending Now\" movies={trending.value} /\u003e\n              \u003cRow title=\"Top Rated\" movies={topRated.value} /\u003e\n              \u003cRow title=\"Lotsoflex Originals\" movies={lotsofflexOriginals.value} category=\"tv\" /\u003e\n              \u003cRow title=\"Action Thrillers\" movies={actionMovies.value} category=\"movie\" /\u003e\n              \u003cRow title=\"Comedies\" movies={comedyMovies.value} category=\"movie\" /\u003e\n              \u003cRow title=\"Scary Movies\" movies={horrorMovies.value} category=\"movie\" /\u003e\n              \u003cRow title=\"Romance Movies\" movies={romanceMovies.value} category=\"movie\" /\u003e\n              \u003cRow title=\"Documentaries\" movies={documentaries.value} category=\"movie\" /\u003e\n            \u003c/section\u003e\n          \u003c/\u003e\n        )}\n      \u003c/main\u003e\n    \u003c/div\u003e\n  );\n});\n\nexport const head: DocumentHead = {\n  title: \"Lotsoflex - Stream Movies \u0026 TV Shows\",\n  meta: [\n    {\n      name: \"description\",\n      content: \"A streaming platform built as a school project, no ads, may all your favourite movies and shows be here\",\n    },\n  ],\n};","fullPath":"src/routes/index.tsx","isBinary":false,"lastModified":1771364966261},"src/components/banner":{"name":"banner","type":"folder","fullPath":"src/components/banner","lastModified":1771364966262},"src/components/navbar":{"name":"navbar","type":"folder","fullPath":"src/components/navbar","lastModified":1771364966262},"src/entry.preview.tsx":{"name":"entry.preview.tsx","type":"file","contents":"/*\n * WHAT IS THIS FILE?\n *\n * It's the entry point for the express server when building for production.\n *\n * Learn more about the cloudflare integration here:\n * - https://qwik.builder.io/deployments/node/\n *\n */\nimport {\n  createQwikCity,\n  type PlatformNode,\n} from \"@builder.io/qwik-city/middleware/node\";\nimport qwikCityPlan from \"@qwik-city-plan\";\nimport { manifest } from \"@qwik-client-manifest\";\nimport render from \"./entry.ssr\";\n\ndeclare global {\n  interface QwikCityPlatform extends PlatformNode {}\n}\n\nconst { router, notFound } = createQwikCity({\n  render,\n  qwikCityPlan,\n  manifest,\n});\n\nexport { router, notFound };","fullPath":"src/entry.preview.tsx","isBinary":false,"lastModified":1771364966261},"src/routes/layout.tsx":{"name":"layout.tsx","type":"file","contents":"import { component$, Slot } from \"@builder.io/qwik\";\nimport type { RequestHandler } from \"@builder.io/qwik-city\";\n\nexport const onGet: RequestHandler = async ({ cacheControl }) =\u003e {\n  // Control caching for this request for best performance and to reduce hosting costs:\n  // https://qwik.builder.io/docs/caching/\n  cacheControl({\n    // Always serve a cached response by default, up to a week stale\n    staleWhileRevalidate: 60 * 60 * 24 * 7,\n    // Max once every 5 seconds, revalidate on the server to get a fresh version of this page\n    maxAge: 5,\n  });\n};\n\nexport default component$(() =\u003e {\n  return \u003cSlot /\u003e;\n});","fullPath":"src/routes/layout.tsx","isBinary":false,"lastModified":1771364966261},"src/routes/movie/[id]":{"name":"[id]","type":"folder","fullPath":"src/routes/movie/[id]","lastModified":1771364966261},"src/routes/watch/[id]":{"name":"[id]","type":"folder","fullPath":"src/routes/watch/[id]","lastModified":1771364966261},"public/lotsoflex-logo.png":{"name":"lotsoflex-logo.png","type":"file","contents":"","fullPath":"public/lotsoflex-logo.png","isBinary":true,"lastModified":1771364966261},"src/components/router-head":{"name":"router-head","type":"folder","fullPath":"src/components/router-head","lastModified":1771364966262},"src/components/row/row.tsx":{"name":"row.tsx","type":"file","contents":"import { component$, useSignal, $ } from \"@builder.io/qwik\";\nimport { Link } from \"@builder.io/qwik-city\";\nimport type { Movie } from \"~/types\";\nimport styles from \"./row.module.css\";\n\ninterface RowProps {\n  title: string;\n  movies: Movie[];\n  category?: string;\n}\n\nexport const Row = component$\u003cRowProps\u003e(({ title, movies, category = \"movie\" }) =\u003e {\n  const isMoved = useSignal(false);\n\n  const handleClick = $((direction: \"left\" | \"right\") =\u003e {\n    isMoved.value = true;\n    const row = document.querySelector(`[data-row=\"${title}\"]`) as HTMLDivElement;\n    if (row) {\n      const { scrollLeft, clientWidth } = row;\n      const scrollTo = direction === \"left\" ? scrollLeft - clientWidth : scrollLeft + clientWidth;\n      row.scrollTo({ left: scrollTo, behavior: \"smooth\" });\n    }\n  });\n\n  const getMediaType = (movie: Movie) =\u003e {\n    // If media_type is explicitly set and valid, use it\n    if (movie.media_type === \"tv\" || movie.media_type === \"movie\") {\n      return movie.media_type;\n    }\n    // If the item has a 'name' property and no 'title', it's a TV show\n    if (movie.name \u0026\u0026 !movie.title) {\n      return \"tv\";\n    }\n    // If the item has a 'title' property and no 'name', it's a movie\n    if (movie.title \u0026\u0026 !movie.name) {\n      return \"movie\";\n    }\n    // Use the category prop as fallback\n    return category === \"tv\" ? \"tv\" : \"movie\";\n  };\n\n  return (\n    \u003cdiv class={styles.row}\u003e\n      \u003ch2 class={styles.title}\u003e\n        {title}\n      \u003c/h2\u003e\n      \u003cdiv class={styles.container}\u003e\n        \u003cbutton\n          class={`${styles.navButton} ${styles.navButtonLeft} ${!isMoved.value ? styles.navButtonHidden : ''}`}\n          onClick$={() =\u003e handleClick(\"left\")}\n          aria-label=\"Scroll left\"\n        \u003e\n          \u003csvg class={styles.navIcon} fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n            \u003cpath fill-rule=\"evenodd\" d=\"M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z\" clip-rule=\"evenodd\" /\u003e\n          \u003c/svg\u003e\n        \u003c/button\u003e\n\n        \u003cdiv\n          data-row={title}\n          class={styles.scrollContainer}\n        \u003e\n          {movies.map((movie) =\u003e (\n            \u003cdiv\n              key={movie.id}\n              class={styles.movieCard}\n            \u003e\n              \u003cLink href={`/${getMediaType(movie)}/${movie.id}`} class={styles.movieLink}\u003e\n                \u003cspan style=\"position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;\"\u003e\n                  View {movie.title || movie.name}\n                \u003c/span\u003e\n              \u003c/Link\u003e\n              \u003cimg\n                src={`https://image.tmdb.org/t/p/w500${movie.backdrop_path || movie.poster_path}`}\n                alt={movie.title || movie.name || movie.original_name || \"\"}\n                class={styles.movieImage}\n              /\u003e\n\n              \u003cdiv class={styles.overlay}\u003e\u003c/div\u003e\n\n              \u003cdiv class={styles.actions}\u003e\n                \u003cLink\n                  href={`/watch/${movie.id}?type=${getMediaType(movie)}`}\n                  class={styles.playButton}\n                  aria-label={`Play ${movie.title || movie.name}`}\n                \u003e\n                  \u003csvg class={styles.playIcon} fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n                    \u003cpath fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z\" clip-rule=\"evenodd\" /\u003e\n                  \u003c/svg\u003e\n                \u003c/Link\u003e\n\n                \u003cLink\n                  href={`/${getMediaType(movie)}/${movie.id}`}\n                  class={styles.infoButton}\n                  aria-label={`More info about ${movie.title || movie.name}`}\n                \u003e\n                  \u003csvg class={styles.infoIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                    \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" /\u003e\n                  \u003c/svg\u003e\n                \u003c/Link\u003e\n\n                \u003cbutton class={styles.addButton} aria-label={`Add ${movie.title || movie.name} to list`}\u003e\n                  \u003csvg class={styles.addIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                    \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M12 6v6m0 0v6m0-6h6m-6 0H6\" /\u003e\n                  \u003c/svg\u003e\n                \u003c/button\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n          ))}\n        \u003c/div\u003e\n\n        \u003cbutton\n          class={`${styles.navButton} ${styles.navButtonRight}`}\n          onClick$={() =\u003e handleClick(\"right\")}\n          aria-label=\"Scroll right\"\n        \u003e\n          \u003csvg class={styles.navIcon} fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n            \u003cpath fill-rule=\"evenodd\" d=\"M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z\" clip-rule=\"evenodd\" /\u003e\n          \u003c/svg\u003e\n        \u003c/button\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n  );\n});","fullPath":"src/components/row/row.tsx","isBinary":false,"lastModified":1771364966261},"src/components/search-input":{"name":"search-input","type":"folder","fullPath":"src/components/search-input","lastModified":1771364966262},"src/components/video-player":{"name":"video-player","type":"folder","fullPath":"src/components/video-player","lastModified":1771364966262},"src/routes/index.module.css":{"name":"index.module.css","type":"file","contents":".container {\n  position: relative;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.main {\n  position: relative;\n  padding-bottom: 96px;\n\n}\n\n.loadingContainer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100vh;\n}\n\n.loadingContent {\n  text-align: center;\n}\n\n.loadingLogo {\n  animation: pulse 2s ease-in-out infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.7; }\n}\n\n.sectionsContainer {\n  margin-top: 0;\n}\n\n/* Responsive Design */\n@media (min-width: 768px) {\n  .sectionsContainer {\n    margin-top: 96px;\n  }\n}\n\n@media (min-width: 1024px) {\n  .main {\n  inset: 0;\n  background: linear-gradient(\n    180deg,\n    transparent 0%,\n    rgba(0, 0, 0, 0.2) 30%,\n    rgba(0, 0, 0, 0.6) 70%,\n    rgba(0, 0, 0, 0.9) 100%\n  );\n  }\n}","fullPath":"src/routes/index.module.css","isBinary":false,"lastModified":1771364966261},"src/routes/movies/index.tsx":{"name":"index.tsx","type":"file","contents":"import { component$, useSignal, useTask$ } from \"@builder.io/qwik\";\nimport type { DocumentHead } from \"@builder.io/qwik-city\";\nimport { Navbar } from \"~/components/navbar/navbar\";\nimport { Row } from \"~/components/row/row\";\nimport type { Movie } from \"~/types\";\nimport styles from \"./index.module.css\";\n\nconst API_KEY = import.meta.env.VITE_TMDB_API_KEY;\nconst BASE_URL = \"https://api.themoviedb.org/3\";\n\nexport default component$(() =\u003e {\n  const topRated = useSignal\u003cMovie[]\u003e([]);\n  const actionMovies = useSignal\u003cMovie[]\u003e([]);\n  const comedyMovies = useSignal\u003cMovie[]\u003e([]);\n  const horrorMovies = useSignal\u003cMovie[]\u003e([]);\n  const romanceMovies = useSignal\u003cMovie[]\u003e([]);\n  const documentaries = useSignal\u003cMovie[]\u003e([]);\n  const isLoading = useSignal(true);\n\n  useTask$(async () =\u003e {\n    try {\n      const [\n        topRatedRes,\n        actionRes,\n        comedyRes,\n        horrorRes,\n        romanceRes,\n        docsRes,\n      ] = await Promise.all([\n        fetch(`${BASE_URL}/movie/top_rated?api_key=${API_KEY}\u0026language=en-US`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=28`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=35`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=27`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=10749`),\n        fetch(`${BASE_URL}/discover/movie?api_key=${API_KEY}\u0026language=en-US\u0026with_genres=99`),\n      ]);\n\n      const [\n        topRatedData,\n        actionData,\n        comedyData,\n        horrorData,\n        romanceData,\n        docsData,\n      ] = await Promise.all([\n        topRatedRes.json(),\n        actionRes.json(),\n        comedyRes.json(),\n        horrorRes.json(),\n        romanceRes.json(),\n        docsRes.json(),\n      ]);\n\n      topRated.value = topRatedData.results || [];\n      actionMovies.value = actionData.results || [];\n      comedyMovies.value = comedyData.results || [];\n      horrorMovies.value = horrorData.results || [];\n      romanceMovies.value = romanceData.results || [];\n      documentaries.value = docsData.results || [];\n      isLoading.value = false;\n    } catch (error) {\n      console.error(\"Error fetching movies:\", error);\n      isLoading.value = false;\n    }\n  });\n\n  if (isLoading.value) {\n    return (\n      \u003cdiv class={styles.loadingContainer}\u003e\n        \u003cdiv class={styles.loadingContent}\u003e\n          \u003cimg src=\"/lotsoflex-logo.png\" alt=\"Lotsoflex\" width={120} height={32} class={styles.loadingLogo} /\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    );\n  }\n\n  return (\n    \u003cdiv class={styles.container}\u003e\n      \u003cNavbar /\u003e\n\n      \u003cmain class={styles.main}\u003e\n        \u003ch1 class={styles.pageTitle}\u003eMovies\u003c/h1\u003e\n\n        \u003csection class={styles.sectionsContainer}\u003e\n          \u003cRow title=\"Top Rated\" movies={topRated.value} category=\"movie\" /\u003e\n          \u003cRow title=\"Action Thrillers\" movies={actionMovies.value} category=\"movie\" /\u003e\n          \u003cRow title=\"Comedies\" movies={comedyMovies.value} category=\"movie\" /\u003e\n          \u003cRow title=\"Scary Movies\" movies={horrorMovies.value} category=\"movie\" /\u003e\n          \u003cRow title=\"Romance Movies\" movies={romanceMovies.value} category=\"movie\" /\u003e\n          \u003cRow title=\"Documentaries\" movies={documentaries.value} category=\"movie\" /\u003e\n        \u003c/section\u003e\n      \u003c/main\u003e\n    \u003c/div\u003e\n  );\n});\n\nexport const head: DocumentHead = {\n  title: \"Movies - Lotsoflex\",\n  meta: [\n    {\n      name: \"description\",\n      content: \"Browse our collection of movies including top rated, action, comedy, horror, romance, and documentaries.\",\n    },\n  ],\n};","fullPath":"src/routes/movies/index.tsx","isBinary":false,"lastModified":1771364966261},"src/routes/search/index.tsx":{"name":"index.tsx","type":"file","contents":"import { component$, useSignal, useTask$ } from \"@builder.io/qwik\";\nimport type { DocumentHead } from \"@builder.io/qwik-city\";\nimport { useLocation, Link } from \"@builder.io/qwik-city\";\nimport { Navbar } from \"~/components/navbar/navbar\";\nimport type { Movie } from \"~/types\";\nimport styles from \"./index.module.css\";\n\nconst API_KEY = import.meta.env.VITE_TMDB_API_KEY;\nconst BASE_URL = \"https://api.themoviedb.org/3\";\n\nexport default component$(() =\u003e {\n  const location = useLocation();\n  const results = useSignal\u003cMovie[]\u003e([]);\n  const isLoading = useSignal(false);\n  const hasError = useSignal(false);\n  const query = location.url.searchParams.get(\"q\") || \"\";\n\n  const performSearch = async (searchQuery: string) =\u003e {\n    if (!searchQuery.trim()) {\n      results.value = [];\n      return;\n    }\n\n    isLoading.value = true;\n    hasError.value = false;\n    \n    try {\n      const response = await fetch(\n        `${BASE_URL}/search/multi?api_key=${API_KEY}\u0026language=en-US\u0026query=${encodeURIComponent(searchQuery)}\u0026page=1\u0026include_adult=false`\n      );\n      \n      if (!response.ok) {\n        throw new Error(`Search failed: ${response.status}`);\n      }\n      \n      const data = await response.json();\n      results.value = data.results?.filter((item: Movie) =\u003e \n        item.media_type !== 'person' \u0026\u0026 (item.backdrop_path || item.poster_path)\n      ) || [];\n    } catch (error) {\n      console.error(\"Error searching:\", error);\n      hasError.value = true;\n      results.value = [];\n    } finally {\n      isLoading.value = false;\n    }\n  };\n\n  useTask$(async ({ track }) =\u003e {\n    track(() =\u003e query);\n    \n    if (query) {\n      await performSearch(query);\n    } else {\n      results.value = [];\n    }\n  });\n\n  const getMediaType = (result: Movie) =\u003e {\n    // If media_type is explicitly set and valid, use it\n    if (result.media_type === \"tv\" || result.media_type === \"movie\") {\n      return result.media_type;\n    }\n    // If the item has a 'name' property and no 'title', it's a TV show\n    if (result.name \u0026\u0026 !result.title) {\n      return \"tv\";\n    }\n    // If the item has a 'title' property and no 'name', it's a movie\n    if (result.title \u0026\u0026 !result.name) {\n      return \"movie\";\n    }\n    // Default to movie for search results\n    return \"movie\";\n  };\n\n  return (\n    \u003cdiv class={styles.container}\u003e\n      \u003cNavbar /\u003e\n\n      \u003cmain class={styles.main}\u003e\n        \u003ch1 class={styles.pageTitle}\u003e\n          {query ? `Search results for: \"${query}\"` : \"Search for movies and TV shows\"}\n        \u003c/h1\u003e\n\n        {isLoading.value ? (\n          \u003cdiv class={styles.loadingContainer}\u003e\n            \u003cdiv class={styles.loadingSpinner}\u003e\u003c/div\u003e\n            \u003cp class={styles.loadingText}\u003eSearching...\u003c/p\u003e\n          \u003c/div\u003e\n        ) : hasError.value ? (\n          \u003cdiv class={styles.errorContainer}\u003e\n            \u003cp class={styles.errorTitle}\u003eSearch failed\u003c/p\u003e\n            \u003cp class={styles.errorMessage}\u003ePlease try again or check your connection.\u003c/p\u003e\n          \u003c/div\u003e\n        ) : !query ? (\n          \u003cp class={styles.emptyMessage}\u003eEnter a search term in the search box above to find movies and TV shows.\u003c/p\u003e\n        ) : results.value.length \u003e 0 ? (\n          \u003cdiv class={styles.resultsGrid}\u003e\n            {results.value.map((result) =\u003e (\n              \u003cLink\n                key={result.id}\n                href={`/${getMediaType(result)}/${result.id}`}\n                class={styles.resultCard}\n              \u003e\n                \u003cimg\n                  src={`https://image.tmdb.org/t/p/w500${result.poster_path || result.backdrop_path}`}\n                  alt={result.title || result.name || result.original_name || \"\"}\n                  class={styles.resultImage}\n                /\u003e\n\n                \u003cdiv class={styles.resultOverlay}\u003e\n                  \u003ch2 class={styles.resultTitle}\u003e\n                    {result.title || result.name || result.original_name}\n                  \u003c/h2\u003e\n                  {(result.release_date || result.first_air_date) \u0026\u0026 (\n                    \u003cp class={styles.resultYear}\u003e\n                      {(result.release_date || result.first_air_date)?.split(\"-\")[0]}\n                    \u003c/p\u003e\n                  )}\n                  {result.vote_average \u0026\u0026 result.vote_average \u003e 0 \u0026\u0026 (\n                    \u003cp class={styles.resultRating}\u003e\n                      ⭐ {result.vote_average.toFixed(1)}\n                    \u003c/p\u003e\n                  )}\n                \u003c/div\u003e\n\n                \u003cdiv class={styles.playButton}\u003e\n                  \u003csvg class={styles.playIcon} fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n                    \u003cpath fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z\" clip-rule=\"evenodd\" /\u003e\n                  \u003c/svg\u003e\n                \u003c/div\u003e\n              \u003c/Link\u003e\n            ))}\n          \u003c/div\u003e\n        ) : (\n          \u003cdiv class={styles.noResultsContainer}\u003e\n            \u003cp class={styles.noResultsTitle}\u003eNo results found for \"{query}\"\u003c/p\u003e\n            \u003cp class={styles.noResultsMessage}\u003eTry different keywords or check your spelling.\u003c/p\u003e\n          \u003c/div\u003e\n        )}\n      \u003c/main\u003e\n    \u003c/div\u003e\n  );\n});\n\nexport const head: DocumentHead = ({ url }) =\u003e {\n  const query = new URL(url).searchParams.get(\"q\");\n  return {\n    title: query ? `Search: ${query} - Lotsoflex` : \"Search - Lotsoflex\",\n    meta: [\n      {\n        name: \"description\",\n        content: query ? `Search results for \"${query}\" on Lotsoflex` : \"Search for movies and TV shows on Lotsoflex\",\n      },\n    ],\n  };\n};","fullPath":"src/routes/search/index.tsx","isBinary":false,"lastModified":1771364966261},"src/routes/my-list/index.tsx":{"name":"index.tsx","type":"file","contents":"import { component$, useStore, $ } from \"@builder.io/qwik\";\nimport type { DocumentHead } from \"@builder.io/qwik-city\";\nimport { Link } from \"@builder.io/qwik-city\";\nimport { Navbar } from \"~/components/navbar/navbar\";\nimport type { Movie } from \"~/types\";\nimport styles from \"./index.module.css\";\n\nexport default component$(() =\u003e {\n  // In a real app, this would come from a global state or local storage\n  const myList = useStore\u003cMovie[]\u003e([]);\n\n  const handleRemove = $((id: number) =\u003e {\n    const index = myList.findIndex(movie =\u003e movie.id === id);\n    if (index \u003e -1) {\n      myList.splice(index, 1);\n    }\n  });\n\n  const getMediaType = (movie: Movie) =\u003e {\n    // If media_type is explicitly set and valid, use it\n    if (movie.media_type === \"tv\" || movie.media_type === \"movie\") {\n      return movie.media_type;\n    }\n    // If the item has a 'name' property and no 'title', it's a TV show\n    if (movie.name \u0026\u0026 !movie.title) {\n      return \"tv\";\n    }\n    // If the item has a 'title' property and no 'name', it's a movie\n    if (movie.title \u0026\u0026 !movie.name) {\n      return \"movie\";\n    }\n    // Default to movie\n    return \"movie\";\n  };\n\n  return (\n    \u003cdiv class={styles.container}\u003e\n      \u003cNavbar /\u003e\n\n      \u003cmain class={styles.main}\u003e\n        \u003ch1 class={styles.pageTitle}\u003eMy List\u003c/h1\u003e\n\n        {myList.length \u003e 0 ? (\n          \u003cdiv class={styles.grid}\u003e\n            {myList.map((movie) =\u003e (\n              \u003cdiv\n                key={movie.id}\n                class={styles.movieCard}\n              \u003e\n                \u003cimg\n                  src={`https://image.tmdb.org/t/p/w500${movie.backdrop_path || movie.poster_path}`}\n                  alt={movie.title || movie.name || movie.original_name || \"\"}\n                  class={styles.movieImage}\n                /\u003e\n\n                \u003cdiv class={styles.overlay}\u003e\u003c/div\u003e\n\n                \u003cbutton\n                  class={styles.removeButton}\n                  onClick$={() =\u003e handleRemove(movie.id)}\n                  aria-label={`Remove ${movie.title || movie.name} from list`}\n                \u003e\n                  \u003csvg class={styles.removeIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                    \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M5 13l4 4L19 7\" /\u003e\n                  \u003c/svg\u003e\n                \u003c/button\u003e\n\n                \u003cdiv class={styles.content}\u003e\n                  \u003ch2 class={styles.title}\u003e\n                    {movie.title || movie.name || movie.original_name}\n                  \u003c/h2\u003e\n\n                  \u003cdiv class={styles.actions}\u003e\n                    \u003cLink\n                      href={`/watch/${movie.id}?type=${getMediaType(movie)}`}\n                      class={styles.playButton}\n                    \u003e\n                      \u003csvg class={styles.playIcon} fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n                        \u003cpath fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z\" clip-rule=\"evenodd\" /\u003e\n                      \u003c/svg\u003e\n                      \u003cspan\u003ePlay\u003c/span\u003e\n                    \u003c/Link\u003e\n\n                    \u003cLink\n                      href={`/${getMediaType(movie)}/${movie.id}`}\n                      class={styles.infoButton}\n                    \u003e\n                      More Info\n                    \u003c/Link\u003e\n                  \u003c/div\u003e\n                \u003c/div\u003e\n              \u003c/div\u003e\n            ))}\n          \u003c/div\u003e\n        ) : (\n          \u003cdiv class={styles.emptyContainer}\u003e\n            \u003cp class={styles.emptyTitle}\u003eYour list is empty.\u003c/p\u003e\n            \u003cp class={styles.emptyMessage}\u003e\n              Add movies and TV shows to your list by clicking the + button when browsing.\n            \u003c/p\u003e\n          \u003c/div\u003e\n        )}\n      \u003c/main\u003e\n    \u003c/div\u003e\n  );\n});\n\nexport const head: DocumentHead = {\n  title: \"My List - Lotsoflex\",\n  meta: [\n    {\n      name: \"description\",\n      content: \"Your personal list of saved movies and TV shows.\",\n    },\n  ],\n};","fullPath":"src/routes/my-list/index.tsx","isBinary":false,"lastModified":1771364966261},"src/routes/tv/[id]/index.tsx":{"name":"index.tsx","type":"file","contents":"import { component$, useSignal, useTask$ } from \"@builder.io/qwik\";\nimport type { DocumentHead } from \"@builder.io/qwik-city\";\nimport { useLocation, Link } from \"@builder.io/qwik-city\";\nimport { Navbar } from \"~/components/navbar/navbar\";\nimport type { TvShowDetails } from \"~/types\";\nimport styles from \"./index.module.css\";\n\nconst API_KEY = import.meta.env.VITE_TMDB_API_KEY;\nconst BASE_URL = \"https://api.themoviedb.org/3\";\n\nexport default component$(() =\u003e {\n  const location = useLocation();\n  const show = useSignal\u003cTvShowDetails | null\u003e(null);\n  const isLoading = useSignal(true);\n  const id = location.params.id;\n\n  useTask$(async () =\u003e {\n    try {\n      const response = await fetch(\n        `${BASE_URL}/tv/${id}?api_key=${API_KEY}\u0026language=en-US\u0026append_to_response=videos,similar,credits`\n      );\n      const data = await response.json();\n      show.value = data;\n    } catch (error) {\n      console.error(\"Error fetching TV show:\", error);\n    } finally {\n      isLoading.value = false;\n    }\n  });\n\n  if (isLoading.value) {\n    return (\n      \u003cdiv class={styles.loadingContainer}\u003e\n        \u003cdiv class={styles.loadingContent}\u003e\n          \u003cimg src=\"/lotsoflex-logo.png\" alt=\"Lotsoflex\" width={120} height={32} class={styles.loadingLogo} /\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    );\n  }\n\n  if (!show.value) {\n    return (\n      \u003cdiv class={styles.notFoundContainer}\u003e\n        \u003cp class={styles.notFoundMessage}\u003eTV show not found\u003c/p\u003e\n      \u003c/div\u003e\n    );\n  }\n\n  const trailer = show.value.videos?.results.find((video) =\u003e video.type === \"Trailer\" || video.type === \"Teaser\");\n  const creator = show.value.created_by?.[0];\n  const cast = show.value.credits?.cast.slice(0, 5);\n\n  return (\n    \u003cdiv class={styles.container}\u003e\n      \u003cNavbar /\u003e\n\n      \u003cmain class={styles.main}\u003e\n        \u003cdiv class={styles.heroSection}\u003e\n          {(show.value.backdrop_path || show.value.poster_path) \u0026\u0026 (\n            \u003cimg\n              src={`https://image.tmdb.org/t/p/original${show.value.backdrop_path || show.value.poster_path}`}\n              alt={show.value.name || \"TV Show\"}\n              class={styles.heroImage}\n            /\u003e\n          )}\n          \u003cdiv class={styles.heroOverlay} /\u003e\n        \u003c/div\u003e\n\n        \u003cdiv class={styles.content}\u003e\n          \u003ch1 class={styles.title}\u003e{show.value.name}\u003c/h1\u003e\n\n          \u003cdiv class={styles.metadata}\u003e\n            \u003cp class={styles.matchScore}\u003e{Math.round(show.value.vote_average * 10)}% Match\u003c/p\u003e\n            \u003cp class={styles.year}\u003e{show.value.first_air_date?.split(\"-\")[0]}\u003c/p\u003e\n            \u003cp class={styles.seasons}\u003e\n              {show.value.number_of_seasons} Season{show.value.number_of_seasons !== 1 ? \"s\" : \"\"}\n            \u003c/p\u003e\n            \u003cspan class={styles.hdBadge}\u003eHD\u003c/span\u003e\n          \u003c/div\u003e\n\n          \u003cdiv class={styles.actions}\u003e\n            \u003cLink\n              href={`/watch/${id}?type=tv`}\n              class={styles.playButton}\n            \u003e\n              \u003csvg class={styles.playIcon} fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n                \u003cpath fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z\" clip-rule=\"evenodd\" /\u003e\n              \u003c/svg\u003e\n              \u003cspan\u003ePlay\u003c/span\u003e\n            \u003c/Link\u003e\n            \u003cbutton class={styles.listButton}\u003e\n              \u003csvg class={styles.listIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M12 6v6m0 0v6m0-6h6m-6 0H6\" /\u003e\n              \u003c/svg\u003e\n              \u003cspan\u003eMy List\u003c/span\u003e\n            \u003c/button\u003e\n            \u003cbutton class={styles.likeButton}\u003e\n              \u003csvg class={styles.likeIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5\" /\u003e\n              \u003c/svg\u003e\n            \u003c/button\u003e\n          \u003c/div\u003e\n\n          \u003cdiv class={styles.description}\u003e\n            \u003cp class={styles.overview}\u003e{show.value.overview}\u003c/p\u003e\n\n            \u003cdiv class={styles.details}\u003e\n              {creator \u0026\u0026 (\n                \u003cp class={styles.detailItem}\u003e\n                  \u003cspan class={styles.detailLabel}\u003eCreator:\u003c/span\u003e {creator.name}\n                \u003c/p\u003e\n              )}\n\n              {cast \u0026\u0026 cast.length \u003e 0 \u0026\u0026 (\n                \u003cp class={styles.detailItem}\u003e\n                  \u003cspan class={styles.detailLabel}\u003eCast:\u003c/span\u003e {cast.map((person) =\u003e person.name).join(\", \")}\n                \u003c/p\u003e\n              )}\n\n              {show.value.genres \u0026\u0026 (\n                \u003cp class={styles.detailItem}\u003e\n                  \u003cspan class={styles.detailLabel}\u003eGenres:\u003c/span\u003e {show.value.genres.map((genre) =\u003e genre.name).join(\", \")}\n                \u003c/p\u003e\n              )}\n            \u003c/div\u003e\n          \u003c/div\u003e\n        \u003c/div\u003e\n      \u003c/main\u003e\n    \u003c/div\u003e\n  );\n});\n\n// Head export for SEO, matching the movie page logic\nexport const head: DocumentHead = async ({ params }) =\u003e {\n  const id = params.id;\n  try {\n    const response = await fetch(`${BASE_URL}/tv/${id}?api_key=${API_KEY}\u0026language=en-US`);\n    const show = await response.json();\n    return {\n      title: show ? `${show.name} - Lotsoflex` : \"TV Show - Lotsoflex\",\n    };\n  } catch {\n    return {\n      title: \"TV Show - Lotsoflex\",\n    };\n  }\n};\n","fullPath":"src/routes/tv/[id]/index.tsx","isBinary":false,"lastModified":1771364966261},"src/routes/tv-shows/index.tsx":{"name":"index.tsx","type":"file","contents":"import { component$, useSignal, useTask$ } from \"@builder.io/qwik\";\nimport type { DocumentHead } from \"@builder.io/qwik-city\";\nimport { Navbar } from \"~/components/navbar/navbar\";\nimport { Row } from \"~/components/row/row\";\nimport type { Movie } from \"~/types\";\nimport styles from \"./index.module.css\";\n\nconst API_KEY = import.meta.env.VITE_TMDB_API_KEY;\nconst BASE_URL = \"https://api.themoviedb.org/3\";\n\nexport default component$(() =\u003e {\n  const tvShows = useSignal\u003cMovie[]\u003e([]);\n  const lotsofflexOriginals = useSignal\u003cMovie[]\u003e([]);\n  const isLoading = useSignal(true);\n\n  useTask$(async () =\u003e {\n    try {\n      const [tvShowsRes, originalsRes] = await Promise.all([\n        fetch(`${BASE_URL}/discover/tv?api_key=${API_KEY}\u0026language=en-US`),\n        fetch(`${BASE_URL}/discover/tv?api_key=${API_KEY}\u0026with_networks=213`),\n      ]);\n\n      const [tvShowsData, originalsData] = await Promise.all([\n        tvShowsRes.json(),\n        originalsRes.json(),\n      ]);\n\n      tvShows.value = tvShowsData.results || [];\n      lotsofflexOriginals.value = originalsData.results || [];\n      isLoading.value = false;\n    } catch (error) {\n      console.error(\"Error fetching TV shows:\", error);\n      isLoading.value = false;\n    }\n  });\n\n  if (isLoading.value) {\n    return (\n      \u003cdiv class={styles.loadingContainer}\u003e\n        \u003cdiv class={styles.loadingContent}\u003e\n          \u003cimg src=\"/lotsoflex-logo.png\" alt=\"Lotsoflex\" width={120} height={32} class={styles.loadingLogo} /\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    );\n  }\n\n  return (\n    \u003cdiv class={styles.container}\u003e\n      \u003cNavbar /\u003e\n\n      \u003cmain class={styles.main}\u003e\n        \u003ch1 class={styles.pageTitle}\u003eTV Shows\u003c/h1\u003e\n\n        \u003csection class={styles.sectionsContainer}\u003e\n          \u003cRow title=\"Lotsoflex Originals\" movies={lotsofflexOriginals.value} category=\"tv\" /\u003e\n          \u003cRow title=\"Popular TV Shows\" movies={tvShows.value} category=\"tv\" /\u003e\n        \u003c/section\u003e\n      \u003c/main\u003e\n    \u003c/div\u003e\n  );\n});\n\nexport const head: DocumentHead = {\n  title: \"TV Shows - Lotsoflex\",\n  meta: [\n    {\n      name: \"description\",\n      content: \"Browse our collection of TV shows including Lotsoflex originals and popular series.\",\n    },\n  ],\n};","fullPath":"src/routes/tv-shows/index.tsx","isBinary":false,"lastModified":1771364966261},"src/routes/movie/[id]/index.tsx":{"name":"index.tsx","type":"file","contents":"import { component$, useSignal, useTask$ } from \"@builder.io/qwik\";\nimport type { DocumentHead } from \"@builder.io/qwik-city\";\nimport { useLocation, Link } from \"@builder.io/qwik-city\";\nimport { Navbar } from \"~/components/navbar/navbar\";\nimport type { MovieDetails } from \"~/types\";\nimport styles from \"./index.module.css\";\n\nconst API_KEY = import.meta.env.VITE_TMDB_API_KEY;\nconst BASE_URL = \"https://api.themoviedb.org/3\";\n\nexport default component$(() =\u003e {\n  const location = useLocation();\n  const movie = useSignal\u003cMovieDetails | null\u003e(null);\n  const isLoading = useSignal(true);\n  const id = location.params.id;\n\n  useTask$(async () =\u003e {\n    try {\n      const response = await fetch(\n        `${BASE_URL}/movie/${id}?api_key=${API_KEY}\u0026language=en-US\u0026append_to_response=videos,similar,credits`\n      );\n      const data = await response.json();\n      movie.value = data;\n    } catch (error) {\n      console.error(\"Error fetching movie:\", error);\n    } finally {\n      isLoading.value = false;\n    }\n  });\n\n  if (isLoading.value) {\n    return (\n      \u003cdiv class={styles.loadingContainer}\u003e\n        \u003cdiv class={styles.loadingContent}\u003e\n          \u003cimg src=\"/lotsoflex-logo.png\" alt=\"Lotsoflex\" width={120} height={32} class={styles.loadingLogo} /\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    );\n  }\n\n  if (!movie.value) {\n    return (\n      \u003cdiv class={styles.notFoundContainer}\u003e\n        \u003cp class={styles.notFoundMessage}\u003eMovie not found\u003c/p\u003e\n      \u003c/div\u003e\n    );\n  }\n\n  const hours = Math.floor(movie.value.runtime / 60);\n  const minutes = movie.value.runtime % 60;\n  const trailer = movie.value.videos?.results.find((video) =\u003e video.type === \"Trailer\" || video.type === \"Teaser\");\n  const director = movie.value.credits?.crew.find((person) =\u003e person.job === \"Director\");\n  const cast = movie.value.credits?.cast.slice(0, 5);\n\n  return (\n    \u003cdiv class={styles.container}\u003e\n      \u003cNavbar /\u003e\n\n      \u003cmain class={styles.main}\u003e\n        \u003cdiv class={styles.heroSection}\u003e\n          \u003cimg\n            src={`https://image.tmdb.org/t/p/original${movie.value.backdrop_path || movie.value.poster_path}`}\n            alt={movie.value.title || \"Movie\"}\n            class={styles.heroImage}\n          /\u003e\n          \u003cdiv class={styles.heroOverlay} /\u003e\n        \u003c/div\u003e\n\n        \u003cdiv class={styles.content}\u003e\n          \u003ch1 class={styles.title}\u003e{movie.value.title}\u003c/h1\u003e\n\n          \u003cdiv class={styles.metadata}\u003e\n            \u003cp class={styles.matchScore}\u003e{Math.round(movie.value.vote_average * 10)}% Match\u003c/p\u003e\n            \u003cp class={styles.year}\u003e{movie.value.release_date?.split(\"-\")[0]}\u003c/p\u003e\n            {movie.value.runtime \u003e 0 \u0026\u0026 (\n              \u003cp class={styles.runtime}\u003e\n                {hours}h {minutes}m\n              \u003c/p\u003e\n            )}\n            \u003cspan class={styles.hdBadge}\u003eHD\u003c/span\u003e\n          \u003c/div\u003e\n\n          \u003cdiv class={styles.actions}\u003e\n            \u003cLink\n              href={`/watch/${id}?type=movie`}\n              class={styles.playButton}\n            \u003e\n              \u003csvg class={styles.playIcon} fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n                \u003cpath fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z\" clip-rule=\"evenodd\" /\u003e\n              \u003c/svg\u003e\n              \u003cspan\u003ePlay\u003c/span\u003e\n            \u003c/Link\u003e\n            \u003cbutton class={styles.listButton}\u003e\n              \u003csvg class={styles.listIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M12 6v6m0 0v6m0-6h6m-6 0H6\" /\u003e\n              \u003c/svg\u003e\n              \u003cspan\u003eMy List\u003c/span\u003e\n            \u003c/button\u003e\n            \u003cbutton class={styles.likeButton}\u003e\n              \u003csvg class={styles.likeIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5\" /\u003e\n              \u003c/svg\u003e\n            \u003c/button\u003e\n          \u003c/div\u003e\n\n          \u003cdiv class={styles.description}\u003e\n            \u003cp class={styles.overview}\u003e{movie.value.overview}\u003c/p\u003e\n\n            \u003cdiv class={styles.details}\u003e\n              {director \u0026\u0026 (\n                \u003cp class={styles.detailItem}\u003e\n                  \u003cspan class={styles.detailLabel}\u003eDirector:\u003c/span\u003e {director.name}\n                \u003c/p\u003e\n              )}\n\n              {cast \u0026\u0026 cast.length \u003e 0 \u0026\u0026 (\n                \u003cp class={styles.detailItem}\u003e\n                  \u003cspan class={styles.detailLabel}\u003eCast:\u003c/span\u003e {cast.map((person) =\u003e person.name).join(\", \")}\n                \u003c/p\u003e\n              )}\n\n              {movie.value.genres \u0026\u0026 (\n                \u003cp class={styles.detailItem}\u003e\n                  \u003cspan class={styles.detailLabel}\u003eGenres:\u003c/span\u003e {movie.value.genres.map((genre) =\u003e genre.name).join(\", \")}\n                \u003c/p\u003e\n              )}\n            \u003c/div\u003e\n          \u003c/div\u003e\n        \u003c/div\u003e\n      \u003c/main\u003e\n    \u003c/div\u003e\n  );\n});\n\nexport const head: DocumentHead = async ({ params }) =\u003e {\n  const id = params.id;\n  try {\n    const response = await fetch(`${BASE_URL}/movie/${id}?api_key=${API_KEY}\u0026language=en-US`);\n    const movie = await response.json();\n    return {\n      title: movie ? `${movie.title} - Lotsoflex` : \"Movie - Lotsoflex\",\n    };\n  } catch {\n    return {\n      title: \"Movie - Lotsoflex\",\n    };\n  }\n};","fullPath":"src/routes/movie/[id]/index.tsx","isBinary":false,"lastModified":1771364966261},"src/routes/watch/[id]/index.tsx":{"name":"index.tsx","type":"file","contents":"import { component$, Resource } from \"@builder.io/qwik\";\nimport type { DocumentHead } from \"@builder.io/qwik-city\";\nimport { routeLoader$ } from \"@builder.io/qwik-city\";\nimport { Navbar } from \"~/components/navbar/navbar\";\nimport { VideoPlayer } from \"~/components/video-player/video-player\";\nimport { StreamingProviders } from \"~/components/streaming-providers/streaming-providers\";\nimport type { MovieDetails, TvShowDetails } from \"~/types\";\nimport styles from \"./index.module.css\";\n\nconst API_KEY = import.meta.env.VITE_TMDB_API_KEY;\nconst BASE_URL = \"https://api.themoviedb.org/3\";\n\nexport const useContentLoader = routeLoader$(async ({ params, url }) =\u003e {\n  const id = params.id;\n  const type = (url.searchParams.get(\"type\") as \"movie\" | \"tv\") || \"movie\";\n\n  try {\n    const response = await fetch(\n      `${BASE_URL}/${type}/${id}?api_key=${API_KEY}\u0026language=en-US\u0026append_to_response=videos,similar,credits`\n    );\n    \n    if (!response.ok) {\n      throw new Error(`Failed to fetch ${type} with id ${id}`);\n    }\n    \n    const data = await response.json();\n    return { content: data, type };\n  } catch (error) {\n    console.error(`Error fetching ${type} content:`, error);\n    throw error;\n  }\n});\n\nexport default component$(() =\u003e {\n  const contentResource = useContentLoader();\n\n  return (\n    \u003cdiv class={styles.container}\u003e\n      \u003cNavbar /\u003e\n\n      \u003cmain class={styles.main}\u003e\n        \u003cResource\n          value={contentResource}\n          onPending={() =\u003e (\n            \u003cdiv class={styles.loadingContainer}\u003e\n              \u003cdiv class={styles.loadingContent}\u003e\n                \u003cimg src=\"/lotsoflex-logo.png\" alt=\"Lotsoflex\" width={120} height={32} class={styles.loadingLogo} /\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n          )}\n          onRejected={() =\u003e (\n            \u003cdiv class={styles.notFoundContainer}\u003e\n              \u003cdiv class={styles.notFoundContent}\u003e\n                \u003cp class={styles.notFoundTitle}\u003eContent not found\u003c/p\u003e\n                \u003cp class={styles.notFoundMessage}\u003eWe couldn't find this title in our database.\u003c/p\u003e\n              \u003c/div\u003e\n            \u003c/div\u003e\n          )}\n          onResolved={({ content, type }) =\u003e {\n            const trailer = content.videos?.results.find((video) =\u003e video.type === \"Trailer\" || video.type === \"Teaser\");\n            const trailerKey = trailer?.key;\n\n            return (\n              \u003cdiv class={styles.content}\u003e\n                \u003ch1 class={styles.pageTitle}\u003e\n                  {(content as any).title || (content as any).name}\n                \u003c/h1\u003e\n\n                \u003cdiv class={styles.videoGrid}\u003e\n                  \u003cVideoPlayer\n                    title=\"Full Content\"\n                    embedUrl={`https://vidsrc.net/embed/${type}/${content.id}`}\n                    fallbackEmbedUrl={`https://embed.vidsrc.pk/${type}/${content.id}`}\n                    autoPlay={true}\n                  /\u003e\n\n                  {trailerKey \u0026\u0026 (\n                    \u003cVideoPlayer\n                      title=\"Trailer\"\n                      embedUrl={`https://www.youtube.com/embed/${trailerKey}`}\n                      autoPlay={false}\n                    /\u003e\n                  )}\n                \u003c/div\u003e\n\n                \u003cdiv class={styles.providersSection}\u003e\n                  \u003cStreamingProviders id={content.id} type={type as \"movie\" | \"tv\"} /\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class={styles.alternativeSection}\u003e\n                  \u003ch2 class={styles.sectionTitle}\u003eAlternative Sources\u003c/h2\u003e\n                  \u003cdiv class={styles.alternativeGrid}\u003e\n                    \u003cVideoPlayer\n                      title=\"Source 2\"\n                      embedUrl={`https://player.vidsrc.co/embed/${type}/${content.id}`}\n                      autoPlay={false}\n                    /\u003e\n                    \u003cVideoPlayer\n                      title=\"Source 3\"\n                      embedUrl={`https://vidsrc.cc/v2/embed/${type}/${content.id}`}\n                      autoPlay={false}\n                    /\u003e\n                    \u003cVideoPlayer\n                      title=\"Source 4\"\n                      embedUrl={`https://player.videasy.net/${type}/${content.id}`}\n                      autoPlay={false}\n                    /\u003e\n                    \u003cVideoPlayer\n                      title=\"Source 5\"\n                      embedUrl={`https://vidsrc.to/embed/${type}/${content.id}`}\n                      autoPlay={false}\n                    /\u003e\n                  \u003c/div\u003e\n                \u003c/div\u003e\n              \u003c/div\u003e\n            );\n          }}\n        /\u003e\n      \u003c/main\u003e\n    \u003c/div\u003e\n  );\n});\n\nexport const head: DocumentHead = ({ resolveValue }) =\u003e {\n  const { content } = resolveValue(useContentLoader);\n  return {\n    title: content ? `${(content as any).title || (content as any).name} - Lotsoflex` : \"Watch - Lotsoflex\",\n  };\n};","fullPath":"src/routes/watch/[id]/index.tsx","isBinary":false,"lastModified":1771364966262},"src/components/banner/banner.tsx":{"name":"banner.tsx","type":"file","contents":"import { component$, useSignal, useTask$ } from \"@builder.io/qwik\";\nimport { Link } from \"@builder.io/qwik-city\";\nimport type { Movie } from \"~/types\";\nimport styles from \"./banner.module.css\";\n\ninterface BannerProps {\n  movies: Movie[];\n}\n\nexport const Banner = component$\u003cBannerProps\u003e(({ movies }) =\u003e {\n  const movie = useSignal\u003cMovie | null\u003e(null);\n\n  useTask$(({ track }) =\u003e {\n    track(() =\u003e movies);\n    if (movies \u0026\u0026 movies.length \u003e 0) {\n      movie.value = movies[Math.floor(Math.random() * movies.length)];\n    }\n  });\n\n  const getMediaType = (movie: Movie) =\u003e {\n    // If media_type is explicitly set and valid, use it\n    if (movie.media_type === \"tv\" || movie.media_type === \"movie\") {\n      return movie.media_type;\n    }\n    // If the item has a 'name' property and no 'title', it's a TV show\n    if (movie.name \u0026\u0026 !movie.title) {\n      return \"tv\";\n    }\n    // If the item has a 'title' property and no 'name', it's a movie\n    if (movie.title \u0026\u0026 !movie.name) {\n      return \"movie\";\n    }\n    // Default to movie for banner (Netflix originals are usually TV shows, but we need to be more specific)\n    return \"tv\";\n  };\n\n  if (!movie.value) return null;\n\n  return (\n    \u003cdiv class={styles.banner}\u003e\n      \u003cdiv class={styles.backgroundContainer}\u003e\n        \u003cimg\n          src={`https://image.tmdb.org/t/p/original${movie.value?.backdrop_path || movie.value?.poster_path}`}\n          alt={movie.value?.title || movie.value?.name || movie.value?.original_name || \"\"}\n          class={styles.backgroundImage}\n        /\u003e\n        \u003cdiv class={styles.overlay} /\u003e\n      \u003c/div\u003e\n\n      \u003cdiv class={styles.content}\u003e\n        \u003ch1 class={styles.title}\u003e\n          {movie.value?.title || movie.value?.name || movie.value?.original_name}\n        \u003c/h1\u003e\n        \u003cp class={styles.description}\u003e\n          {movie.value?.overview}\n        \u003c/p\u003e\n        \u003cdiv class={styles.actions}\u003e\n          \u003cLink\n            href={`/watch/${movie.value.id}?type=${getMediaType(movie.value)}`}\n            class={styles.playButton}\n          \u003e\n            \u003csvg class={styles.playIcon} fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n              \u003cpath fill-rule=\"evenodd\" d=\"M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z\" clip-rule=\"evenodd\" /\u003e\n            \u003c/svg\u003e\n            \u003cspan\u003ePlay\u003c/span\u003e\n          \u003c/Link\u003e\n          \u003cLink\n            href={`/${getMediaType(movie.value)}/${movie.value.id}`}\n            class={styles.infoButton}\n          \u003e\n            \u003csvg class={styles.infoIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n              \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z\" /\u003e\n            \u003c/svg\u003e\n            \u003cspan\u003eMore Info\u003c/span\u003e\n          \u003c/Link\u003e\n        \u003c/div\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n  );\n});","fullPath":"src/components/banner/banner.tsx","isBinary":false,"lastModified":1771364966262},"src/components/navbar/navbar.tsx":{"name":"navbar.tsx","type":"file","contents":"import { component$, useSignal, useVisibleTask$ } from \"@builder.io/qwik\";\nimport { Link } from \"@builder.io/qwik-city\";\nimport { SearchInput } from \"../search-input/search-input\";\nimport styles from \"./navbar.module.css\";\n\nexport const Navbar = component$(() =\u003e {\n  const isScrolled = useSignal(false);\n  const isMobileMenuOpen = useSignal(false);\n\n  useVisibleTask$(() =\u003e {\n    const handleScroll = () =\u003e {\n      isScrolled.value = window.scrollY \u003e 0;\n    };\n\n    window.addEventListener(\"scroll\", handleScroll);\n    return () =\u003e window.removeEventListener(\"scroll\", handleScroll);\n  });\n\n  return (\n    \u003cheader class={`${styles.navbar} ${isScrolled.value ? styles.scrolled : styles.transparent}`}\u003e\n      \u003cdiv class={styles.container}\u003e\n        \u003cLink href=\"/\" class={styles.logo}\u003e\n          \u003cimg\n            src=\"/lotsoflex-logo.png\"\n            alt=\"Lotsoflex\"\n            width={120}\n            height={32}\n            class={styles.logo}\n          /\u003e\n        \u003c/Link\u003e\n\n        \u003cnav class={styles.nav}\u003e\n          \u003cul class={styles.navList}\u003e\n            \u003cli\u003e\n              \u003cLink href=\"/\" class={styles.navLink}\u003e\n                Home\n              \u003c/Link\u003e\n            \u003c/li\u003e\n            \u003cli\u003e\n              \u003cLink href=\"/tv-shows\" class={styles.navLink}\u003e\n                TV Shows\n              \u003c/Link\u003e\n            \u003c/li\u003e\n            \u003cli\u003e\n              \u003cLink href=\"/movies\" class={styles.navLink}\u003e\n                Movies\n              \u003c/Link\u003e\n            \u003c/li\u003e\n            \u003cli\u003e\n              \u003cLink href=\"/my-list\" class={styles.navLink}\u003e\n                My List\n              \u003c/Link\u003e\n            \u003c/li\u003e\n          \u003c/ul\u003e\n        \u003c/nav\u003e\n\n        \u003cdiv class={styles.spacer}\u003e\u003c/div\u003e\n\n        \u003cdiv class={styles.actions}\u003e\n          \u003cSearchInput /\u003e\n          \u003cbutton class={styles.iconButton} aria-label=\"Notifications\"\u003e\n            \u003csvg width=\"20\" height=\"20\" fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n              \u003cpath d=\"M10 2a6 6 0 00-6 6v3.586l-.707.707A1 1 0 004 14h12a1 1 0 00.707-1.707L16 11.586V8a6 6 0 00-6-6zM10 18a3 3 0 01-3-3h6a3 3 0 01-3 3z\" /\u003e\n            \u003c/svg\u003e\n          \u003c/button\u003e\n          \u003cdiv class={styles.profile}\u003e\n            \u003cdiv class={styles.profileImage}\u003e\u003c/div\u003e\n            \u003csvg class={styles.profileArrow} fill=\"currentColor\" viewBox=\"0 0 20 20\"\u003e\n              \u003cpath fill-rule=\"evenodd\" d=\"M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z\" clip-rule=\"evenodd\" /\u003e\n            \u003c/svg\u003e\n          \u003c/div\u003e\n        \u003c/div\u003e\n\n        \u003cbutton \n          class={styles.hamburger}\n          onClick$={() =\u003e isMobileMenuOpen.value = !isMobileMenuOpen.value}\n          aria-label=\"Toggle mobile menu\"\n        \u003e\n          \u003cspan class={styles.hamburgerLine}\u003e\u003c/span\u003e\n          \u003cspan class={styles.hamburgerLine}\u003e\u003c/span\u003e\n          \u003cspan class={styles.hamburgerLine}\u003e\u003c/span\u003e\n        \u003c/button\u003e\n      \u003c/div\u003e\n\n      {isMobileMenuOpen.value \u0026\u0026 (\n        \u003cdiv class={`${styles.mobileMenu} ${styles.open}`}\u003e\n          \u003cul class={styles.mobileNavList}\u003e\n            \u003cli class={styles.mobileNavItem}\u003e\n              \u003cLink href=\"/\" class={styles.mobileNavLink} onClick$={() =\u003e isMobileMenuOpen.value = false}\u003e\n                Home\n              \u003c/Link\u003e\n            \u003c/li\u003e\n            \u003cli class={styles.mobileNavItem}\u003e\n              \u003cLink href=\"/tv-shows\" class={styles.mobileNavLink} onClick$={() =\u003e isMobileMenuOpen.value = false}\u003e\n                TV Shows\n              \u003c/Link\u003e\n            \u003c/li\u003e\n            \u003cli class={styles.mobileNavItem}\u003e\n              \u003cLink href=\"/movies\" class={styles.mobileNavLink} onClick$={() =\u003e isMobileMenuOpen.value = false}\u003e\n                Movies\n              \u003c/Link\u003e\n            \u003c/li\u003e\n            \u003cli class={styles.mobileNavItem}\u003e\n              \u003cLink href=\"/my-list\" class={styles.mobileNavLink} onClick$={() =\u003e isMobileMenuOpen.value = false}\u003e\n                My List\n              \u003c/Link\u003e\n            \u003c/li\u003e\n          \u003c/ul\u003e\n        \u003c/div\u003e\n      )}\n    \u003c/header\u003e\n  );\n});","fullPath":"src/components/navbar/navbar.tsx","isBinary":false,"lastModified":1771364966262},"src/components/row/row.module.css":{"name":"row.module.css","type":"file","contents":".row {\n  height: 160px;\n  margin-bottom: 16px;\n  padding: 0 16px;\n}\n\n.title {\n  width: 224px;\n  cursor: pointer;\n  font-size: 0.875rem;\n  font-weight: 600;\n  color: #ffffff;\n  transition: color 0.3s ease;\n  margin-bottom: 8px;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.title:hover {\n  animation: gradient-shift 1s ease;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.container {\n  position: relative;\n}\n\n.scrollContainer {\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  overflow-x: scroll;\n  scrollbar-width: none;\n  -ms-overflow-style: none;\n  padding: 8px;\n}\n\n.scrollContainer::-webkit-scrollbar {\n  display: none;\n}\n\n.movieCard {\n  position: relative;\n  height: 112px;\n  min-width: 180px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  border-radius: 8px;\n  overflow: hidden;\n  background: linear-gradient(45deg, rgba(229, 9, 20, 0.1), rgba(255, 107, 107, 0.1));\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.movieCard:hover {\n  transform: scale(1.05) translateY(-4px);\n  box-shadow: 0 15px 35px rgba(229, 9, 20, 0.3);\n  border-color: rgba(229, 9, 20, 0.5);\n}\n\n.movieLink {\n  position: absolute;\n  inset: 0;\n  z-index: 10;\n  text-decoration: none;\n}\n\n.movieImage {\n  width: 100%;\n  height: 100%;\n  border-radius: 8px;\n  object-fit: cover;\n  transition: transform 0.3s ease;\n}\n\n.movieCard:hover .movieImage {\n  transform: scale(1.1);\n}\n\n.overlay {\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(\n    180deg,\n    transparent 0%,\n    rgba(0, 0, 0, 0.4) 60%,\n    rgba(0, 0, 0, 0.8) 100%\n  );\n  opacity: 0;\n  transition: opacity 0.3s ease;\n}\n\n.movieCard:hover .overlay {\n  opacity: 1;\n}\n\n.actions {\n  position: absolute;\n  bottom: 8px;\n  left: 8px;\n  right: 8px;\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  z-index: 20;\n  opacity: 0;\n  transform: translateY(10px);\n  transition: all 0.3s ease;\n}\n\n.movieCard:hover .actions {\n  opacity: 1;\n  transform: translateY(0);\n}\n\n.playButton {\n  background: linear-gradient(45deg, #ffffff, #f0f0f0);\n  color: #000000;\n  border: none;\n  border-radius: 50%;\n  padding: 8px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  box-shadow: 0 4px 12px rgba(255, 255, 255, 0.3);\n}\n\n.playButton:hover {\n  transform: scale(1.1);\n  background: linear-gradient(45deg, #f0f0f0, #e0e0e0);\n}\n\n.infoButton {\n  background: rgba(128, 128, 128, 0.6);\n  color: #ffffff;\n  border: none;\n  border-radius: 50%;\n  padding: 8px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  backdrop-filter: blur(10px);\n  border: 1px solid rgba(255, 255, 255, 0.3);\n  text-decoration: none;\n}\n\n.infoButton:hover {\n  background: rgba(255, 255, 255, 0.2);\n  transform: scale(1.1);\n  border-color: rgba(255, 255, 255, 0.5);\n}\n\n.addButton {\n  background: rgba(128, 128, 128, 0.6);\n  color: #ffffff;\n  border: none;\n  border-radius: 50%;\n  padding: 8px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  backdrop-filter: blur(10px);\n  border: 1px solid rgba(255, 255, 255, 0.3);\n}\n\n.addButton:hover {\n  background: rgba(128, 128, 128, 0.8);\n  transform: scale(1.1);\n  border-color: rgba(255, 255, 255, 0.5);\n}\n\n.playIcon, .infoIcon, .addIcon {\n  width: 16px;\n  height: 16px;\n}\n\n.navButton {\n  position: absolute;\n  top: 0;\n  bottom: 0;\n  margin: auto;\n  height: 36px;\n  width: 36px;\n  cursor: pointer;\n  opacity: 0;\n  transition: all 0.3s ease;\n  background: rgba(0, 0, 0, 0.7);\n  border: none;\n  border-radius: 50%;\n  color: #ffffff;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  backdrop-filter: blur(10px);\n  z-index: 40;\n}\n\n.container:hover .navButton {\n  opacity: 1;\n}\n\n.navButton:hover {\n  transform: scale(1.25);\n  background: rgba(229, 9, 20, 0.8);\n  box-shadow: 0 4px 15px rgba(229, 9, 20, 0.4);\n}\n\n.navButtonLeft {\n  left: 8px;\n}\n\n.navButtonRight {\n  right: 8px;\n}\n\n.navButtonHidden {\n  display: none;\n}\n\n.navIcon {\n  width: 20px;\n  height: 20px;\n}\n\n/* Responsive Design */\n@media (min-width: 768px) {\n  .row {\n    height: 180px;\n    padding: 0;\n  }\n  \n  .title {\n    font-size: 1.25rem;\n    margin-bottom: 12px;\n  }\n  \n  .movieCard {\n    height: 144px;\n    min-width: 260px;\n  }\n  \n  .scrollContainer {\n    gap: 8px;\n    padding: 16px;\n    margin: 0 -8px;\n  }\n}\n\n@media (max-width: 480px) {\n  .movieCard {\n    height: 100px;\n    min-width: 160px;\n  }\n  \n  .title {\n    font-size: 0.8rem;\n  }\n}","fullPath":"src/components/row/row.module.css","isBinary":false,"lastModified":1771364966262},"src/components/streaming-providers":{"name":"streaming-providers","type":"folder","fullPath":"src/components/streaming-providers","lastModified":1771364966262},"src/routes/movies/index.module.css":{"name":"index.module.css","type":"file","contents":".container {\n  position: relative;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.main {\n  position: relative;\n  padding-top: 96px;\n  padding-bottom: 96px;\n  padding-left: 16px;\n}\n\n.pageTitle {\n  font-size: 2rem;\n  font-weight: 700;\n  padding: 0 16px;\n  margin-bottom: 24px;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  animation: gradient-shift 4s ease infinite;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.sectionsContainer {\n  margin-top: 0;\n}\n\n.loadingContainer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.loadingContent {\n  text-align: center;\n}\n\n.loadingLogo {\n  animation: pulse 2s ease-in-out infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.7; }\n}\n\n/* Responsive Design */\n@media (min-width: 768px) {\n  .pageTitle {\n    padding: 0;\n    font-size: 2.5rem;\n  }\n  \n  .sectionsContainer {\n    margin-top: 96px;\n  }\n}\n\n@media (min-width: 1024px) {\n  .main {\n    padding-left: 64px;\n  }\n}","fullPath":"src/routes/movies/index.module.css","isBinary":false,"lastModified":1771364966262},"src/routes/search/index.module.css":{"name":"index.module.css","type":"file","contents":".container {\n  position: relative;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.main {\n  position: relative;\n  padding-top: 96px;\n  padding-left: 16px;\n  padding-right: 16px;\n}\n\n.pageTitle {\n  font-size: 1.5rem;\n  font-weight: 700;\n  margin-bottom: 24px;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  animation: gradient-shift 4s ease infinite;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.loadingContainer {\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  justify-content: center;\n  padding: 80px 0;\n  gap: 16px;\n}\n\n.loadingSpinner {\n  width: 48px;\n  height: 48px;\n  border: 4px solid rgba(255, 255, 255, 0.1);\n  border-left: 4px solid #e50914;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n.loadingText {\n  color: rgba(255, 255, 255, 0.6);\n  font-size: 1rem;\n}\n\n.errorContainer {\n  text-align: center;\n  padding: 40px 0;\n}\n\n.errorTitle {\n  color: #e50914;\n  font-size: 1.25rem;\n  font-weight: 600;\n  margin-bottom: 8px;\n}\n\n.errorMessage {\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.emptyMessage {\n  color: rgba(255, 255, 255, 0.6);\n  text-align: center;\n  padding: 40px 0;\n  font-size: 1.125rem;\n}\n\n.resultsGrid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 16px;\n}\n\n.resultCard {\n  position: relative;\n  height: 192px;\n  border-radius: 8px;\n  overflow: hidden;\n  transition: all 0.3s ease;\n  text-decoration: none;\n  background: linear-gradient(45deg, rgba(229, 9, 20, 0.1), rgba(255, 107, 107, 0.1));\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.resultCard:hover {\n  transform: scale(1.05) translateY(-4px);\n  box-shadow: 0 15px 35px rgba(229, 9, 20, 0.3);\n  border-color: rgba(229, 9, 20, 0.5);\n}\n\n.resultImage {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 0.3s ease;\n}\n\n.resultCard:hover .resultImage {\n  transform: scale(1.1);\n}\n\n.resultOverlay {\n  position: absolute;\n  bottom: 0;\n  width: 100%;\n  background: linear-gradient(\n    180deg,\n    transparent 0%,\n    rgba(0, 0, 0, 0.6) 50%,\n    rgba(0, 0, 0, 0.9) 100%\n  );\n  padding: 16px;\n}\n\n.resultTitle {\n  font-size: 0.875rem;\n  font-weight: 600;\n  color: #ffffff;\n  margin-bottom: 4px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.resultYear {\n  font-size: 0.75rem;\n  color: rgba(255, 255, 255, 0.6);\n  margin-bottom: 2px;\n}\n\n.resultRating {\n  font-size: 0.75rem;\n  color: #ffd700;\n  font-weight: 500;\n}\n\n.playButton {\n  position: absolute;\n  top: 8px;\n  right: 8px;\n  background: rgba(0, 0, 0, 0.7);\n  color: #ffffff;\n  border-radius: 50%;\n  padding: 8px;\n  opacity: 0;\n  transform: scale(0.8);\n  transition: all 0.3s ease;\n  backdrop-filter: blur(10px);\n}\n\n.resultCard:hover .playButton {\n  opacity: 1;\n  transform: scale(1);\n}\n\n.playButton:hover {\n  background: rgba(229, 9, 20, 0.8);\n  transform: scale(1.1);\n}\n\n.playIcon {\n  width: 16px;\n  height: 16px;\n}\n\n.noResultsContainer {\n  text-align: center;\n  padding: 40px 0;\n}\n\n.noResultsTitle {\n  font-size: 1.125rem;\n  font-weight: 600;\n  color: rgba(255, 255, 255, 0.6);\n  margin-bottom: 8px;\n}\n\n.noResultsMessage {\n  color: rgba(255, 255, 255, 0.5);\n}\n\n/* Responsive Design */\n@media (min-width: 480px) {\n  .resultsGrid {\n    grid-template-columns: repeat(3, 1fr);\n  }\n}\n\n@media (min-width: 768px) {\n  .main {\n    padding-left: 64px;\n    padding-right: 64px;\n  }\n  \n  .pageTitle {\n    font-size: 2rem;\n  }\n  \n  .resultsGrid {\n    grid-template-columns: repeat(4, 1fr);\n    gap: 24px;\n  }\n  \n  .resultCard {\n    height: 256px;\n  }\n  \n  .resultTitle {\n    font-size: 1rem;\n  }\n  \n  .emptyMessage {\n    font-size: 1.25rem;\n  }\n}\n\n@media (min-width: 1024px) {\n  .resultsGrid {\n    grid-template-columns: repeat(5, 1fr);\n  }\n}","fullPath":"src/routes/search/index.module.css","isBinary":false,"lastModified":1771364966262},"src/routes/my-list/index.module.css":{"name":"index.module.css","type":"file","contents":".container {\n  position: relative;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.main {\n  position: relative;\n  padding-top: 96px;\n  padding-left: 16px;\n  padding-right: 16px;\n}\n\n.pageTitle {\n  font-size: 1.5rem;\n  font-weight: 700;\n  margin-bottom: 24px;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  animation: gradient-shift 4s ease infinite;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 16px;\n}\n\n.movieCard {\n  position: relative;\n  height: 256px;\n  border-radius: 8px;\n  overflow: hidden;\n  transition: all 0.3s ease;\n  background: linear-gradient(45deg, rgba(229, 9, 20, 0.1), rgba(255, 107, 107, 0.1));\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.movieCard:hover {\n  transform: scale(1.05) translateY(-4px);\n  box-shadow: 0 15px 35px rgba(229, 9, 20, 0.3);\n  border-color: rgba(229, 9, 20, 0.5);\n}\n\n.movieImage {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 0.3s ease;\n}\n\n.movieCard:hover .movieImage {\n  transform: scale(1.1);\n}\n\n.overlay {\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(\n    180deg,\n    transparent 0%,\n    rgba(0, 0, 0, 0.4) 60%,\n    rgba(0, 0, 0, 0.8) 100%\n  );\n  opacity: 0;\n  transition: opacity 0.3s ease;\n}\n\n.movieCard:hover .overlay {\n  opacity: 1;\n}\n\n.removeButton {\n  position: absolute;\n  top: 8px;\n  right: 8px;\n  background: rgba(128, 128, 128, 0.6);\n  color: #ffffff;\n  border: none;\n  border-radius: 50%;\n  padding: 8px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  backdrop-filter: blur(10px);\n  border: 1px solid rgba(255, 255, 255, 0.3);\n  opacity: 0;\n  transform: scale(0.8);\n}\n\n.movieCard:hover .removeButton {\n  opacity: 1;\n  transform: scale(1);\n}\n\n.removeButton:hover {\n  background: rgba(229, 9, 20, 0.8);\n  border-color: rgba(229, 9, 20, 0.5);\n  transform: scale(1.1);\n}\n\n.content {\n  position: absolute;\n  bottom: 0;\n  width: 100%;\n  padding: 16px;\n  opacity: 0;\n  transform: translateY(10px);\n  transition: all 0.3s ease;\n}\n\n.movieCard:hover .content {\n  opacity: 1;\n  transform: translateY(0);\n}\n\n.title {\n  font-size: 1rem;\n  font-weight: 600;\n  color: #ffffff;\n  margin-bottom: 8px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.actions {\n  display: flex;\n  gap: 8px;\n}\n\n.playButton {\n  background: linear-gradient(45deg, #ffffff, #f0f0f0);\n  color: #000000;\n  border: none;\n  padding: 8px 12px;\n  border-radius: 6px;\n  font-size: 0.875rem;\n  font-weight: 600;\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  text-decoration: none;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n\n.playButton:hover {\n  transform: translateY(-1px);\n  background: linear-gradient(45deg, #f0f0f0, #e0e0e0);\n}\n\n.infoButton {\n  background: transparent;\n  color: #ffffff;\n  border: 2px solid rgba(255, 255, 255, 0.4);\n  padding: 8px 12px;\n  border-radius: 6px;\n  font-size: 0.875rem;\n  text-decoration: none;\n  cursor: pointer;\n  transition: all 0.3s ease;\n}\n\n.infoButton:hover {\n  background: rgba(255, 255, 255, 0.1);\n  border-color: rgba(255, 255, 255, 0.6);\n  transform: translateY(-1px);\n}\n\n.playIcon, .removeIcon {\n  width: 12px;\n  height: 12px;\n}\n\n.emptyContainer {\n  text-align: center;\n  padding: 40px 0;\n}\n\n.emptyTitle {\n  font-size: 1.125rem;\n  color: rgba(255, 255, 255, 0.6);\n  margin-bottom: 16px;\n}\n\n.emptyMessage {\n  color: rgba(255, 255, 255, 0.5);\n}\n\n/* Responsive Design */\n@media (min-width: 480px) {\n  .grid {\n    grid-template-columns: repeat(3, 1fr);\n  }\n}\n\n@media (min-width: 768px) {\n  .main {\n    padding-left: 64px;\n    padding-right: 64px;\n  }\n  \n  .pageTitle {\n    font-size: 2rem;\n  }\n  \n  .grid {\n    grid-template-columns: repeat(4, 1fr);\n    gap: 24px;\n  }\n  \n  .title {\n    font-size: 1.125rem;\n  }\n}\n\n@media (min-width: 1024px) {\n  .grid {\n    grid-template-columns: repeat(5, 1fr);\n  }\n}","fullPath":"src/routes/my-list/index.module.css","isBinary":false,"lastModified":1771364966262},"src/routes/tv/[id]/index.module.css":{"name":"index.module.css","type":"file","contents":".container {\n  position: relative;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.main {\n  position: relative;\n  padding-top: 64px;\n}\n\n.heroSection {\n  position: relative;\n  height: 70vh;\n  overflow: hidden;\n}\n\n.heroImage {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 8s ease-in-out;\n}\n\n.heroImage:hover {\n  transform: scale(1.05);\n}\n\n.heroOverlay {\n  position: absolute;\n  bottom: 0;\n  width: 100%;\n  height: 50%;\n  background: linear-gradient(\n    180deg,\n    transparent 0%,\n    rgba(0, 0, 0, 0.6) 50%,\n    rgba(0, 0, 0, 0.9) 100%\n  );\n}\n\n.content {\n  padding: 16px;\n  padding-bottom: 96px;\n  margin-top: -128px;\n  position: relative;\n  z-index: 10;\n}\n\n.title {\n  font-size: 2rem;\n  font-weight: 700;\n  margin-bottom: 16px;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  animation: gradient-shift 4s ease infinite;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.metadata {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  margin-bottom: 24px;\n  flex-wrap: wrap;\n}\n\n.matchScore {\n  color: #46d369;\n  font-weight: 600;\n}\n\n.year, .seasons {\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.hdBadge {\n  border: 2px solid rgba(255, 255, 255, 0.4);\n  padding: 2px 8px;\n  font-size: 0.75rem;\n  border-radius: 4px;\n  color: rgba(255, 255, 255, 0.8);\n}\n\n.actions {\n  display: flex;\n  gap: 12px;\n  margin-bottom: 32px;\n  flex-wrap: wrap;\n}\n\n.playButton {\n  background: linear-gradient(45deg, #ffffff, #f0f0f0);\n  color: #000000;\n  border: none;\n  padding: 12px 24px;\n  border-radius: 8px;\n  font-size: 16px;\n  font-weight: 600;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  text-decoration: none;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);\n  position: relative;\n  overflow: hidden;\n}\n\n.playButton::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.1), transparent);\n  transition: left 0.5s;\n}\n\n.playButton:hover::before {\n  left: 100%;\n}\n\n.playButton:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 8px 25px rgba(255, 255, 255, 0.3);\n  background: linear-gradient(45deg, #f0f0f0, #e0e0e0);\n}\n\n.listButton, .likeButton {\n  background: transparent;\n  color: #ffffff;\n  border: 2px solid rgba(255, 255, 255, 0.4);\n  padding: 12px 24px;\n  border-radius: 8px;\n  font-size: 16px;\n  font-weight: 600;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  backdrop-filter: blur(10px);\n  position: relative;\n  overflow: hidden;\n}\n\n.listButton::before, .likeButton::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);\n  transition: left 0.5s;\n}\n\n.listButton:hover::before, .likeButton:hover::before {\n  left: 100%;\n}\n\n.listButton:hover, .likeButton:hover {\n  background: rgba(255, 255, 255, 0.1);\n  border-color: rgba(255, 255, 255, 0.6);\n  transform: translateY(-2px);\n  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);\n}\n\n.playIcon, .listIcon, .likeIcon {\n  width: 16px;\n  height: 16px;\n}\n\n.description {\n  max-width: 768px;\n  margin-bottom: 24px;\n}\n\n.overview {\n  font-size: 1.125rem;\n  line-height: 1.6;\n  color: rgba(255, 255, 255, 0.9);\n}\n\n.details {\n  color: rgba(255, 255, 255, 0.6);\n  line-height: 1.8;\n}\n\n.detailItem {\n  margin-bottom: 8px;\n}\n\n.detailLabel {\n  color: rgba(255, 255, 255, 0.8);\n  font-weight: 500;\n}\n\n.loadingContainer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.loadingContent {\n  text-align: center;\n}\n\n.loadingLogo {\n  animation: pulse 2s ease-in-out infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.7; }\n}\n\n.notFoundContainer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.notFoundMessage {\n  color: #ffffff;\n  font-size: 1.25rem;\n}\n\n/* Responsive Design */\n@media (min-width: 768px) {\n  .content {\n    padding: 64px;\n  }\n  \n  .title {\n    font-size: 3rem;\n  }\n  \n  .overview {\n    font-size: 1.25rem;\n  }\n}\n\n@media (min-width: 1024px) {\n  .title {\n    font-size: 4rem;\n  }\n}\n\n@media (max-width: 480px) {\n  .playButton, .listButton, .likeButton {\n    padding: 10px 20px;\n    font-size: 14px;\n  }\n  \n  .title {\n    font-size: 1.75rem;\n  }\n  \n  .overview {\n    font-size: 1rem;\n  }\n}","fullPath":"src/routes/tv/[id]/index.module.css","isBinary":false,"lastModified":1771364966262},"src/routes/tv-shows/index.module.css":{"name":"index.module.css","type":"file","contents":".container {\n  position: relative;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.main {\n  position: relative;\n  padding-top: 96px;\n  padding-bottom: 96px;\n  padding-left: 16px;\n}\n\n.pageTitle {\n  font-size: 2rem;\n  font-weight: 700;\n  padding: 0 16px;\n  margin-bottom: 24px;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  animation: gradient-shift 4s ease infinite;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.sectionsContainer {\n  margin-top: 0;\n}\n\n.loadingContainer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.loadingContent {\n  text-align: center;\n}\n\n.loadingLogo {\n  animation: pulse 2s ease-in-out infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.7; }\n}\n\n/* Responsive Design */\n@media (min-width: 768px) {\n  .pageTitle {\n    padding: 0;\n    font-size: 2.5rem;\n  }\n  \n  .sectionsContainer {\n    margin-top: 96px;\n  }\n}\n\n@media (min-width: 1024px) {\n  .main {\n    padding-left: 64px;\n  }\n}","fullPath":"src/routes/tv-shows/index.module.css","isBinary":false,"lastModified":1771364966262},"src/routes/movie/[id]/index.module.css":{"name":"index.module.css","type":"file","contents":".container {\n  position: relative;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.main {\n  position: relative;\n  padding-top: 64px;\n}\n\n.heroSection {\n  position: relative;\n  height: 70vh;\n  overflow: hidden;\n}\n\n.heroImage {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 8s ease-in-out;\n}\n\n.heroImage:hover {\n  transform: scale(1.05);\n}\n\n.heroOverlay {\n  position: absolute;\n  bottom: 0;\n  width: 100%;\n  height: 50%;\n  background: linear-gradient(\n    180deg,\n    transparent 0%,\n    rgba(0, 0, 0, 0.6) 50%,\n    rgba(0, 0, 0, 0.9) 100%\n  );\n}\n\n.content {\n  padding: 16px;\n  padding-bottom: 96px;\n  margin-top: -128px;\n  position: relative;\n  z-index: 10;\n}\n\n.title {\n  font-size: 2rem;\n  font-weight: 700;\n  margin-bottom: 16px;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  animation: gradient-shift 4s ease infinite;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.metadata {\n  display: flex;\n  align-items: center;\n  gap: 16px;\n  margin-bottom: 24px;\n  flex-wrap: wrap;\n}\n\n.matchScore {\n  color: #46d369;\n  font-weight: 600;\n}\n\n.year, .runtime {\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.hdBadge {\n  border: 2px solid rgba(255, 255, 255, 0.4);\n  padding: 2px 8px;\n  font-size: 0.75rem;\n  border-radius: 4px;\n  color: rgba(255, 255, 255, 0.8);\n}\n\n.actions {\n  display: flex;\n  gap: 12px;\n  margin-bottom: 32px;\n  flex-wrap: wrap;\n}\n\n.playButton {\n  background: linear-gradient(45deg, #ffffff, #f0f0f0);\n  color: #000000;\n  border: none;\n  padding: 12px 24px;\n  border-radius: 8px;\n  font-size: 16px;\n  font-weight: 600;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  text-decoration: none;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);\n  position: relative;\n  overflow: hidden;\n}\n\n.playButton::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.1), transparent);\n  transition: left 0.5s;\n}\n\n.playButton:hover::before {\n  left: 100%;\n}\n\n.playButton:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 8px 25px rgba(255, 255, 255, 0.3);\n  background: linear-gradient(45deg, #f0f0f0, #e0e0e0);\n}\n\n.listButton, .likeButton {\n  background: transparent;\n  color: #ffffff;\n  border: 2px solid rgba(255, 255, 255, 0.4);\n  padding: 12px 24px;\n  border-radius: 8px;\n  font-size: 16px;\n  font-weight: 600;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  backdrop-filter: blur(10px);\n  position: relative;\n  overflow: hidden;\n}\n\n.listButton::before, .likeButton::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);\n  transition: left 0.5s;\n}\n\n.listButton:hover::before, .likeButton:hover::before {\n  left: 100%;\n}\n\n.listButton:hover, .likeButton:hover {\n  background: rgba(255, 255, 255, 0.1);\n  border-color: rgba(255, 255, 255, 0.6);\n  transform: translateY(-2px);\n  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);\n}\n\n.playIcon, .listIcon, .likeIcon {\n  width: 16px;\n  height: 16px;\n}\n\n.description {\n  max-width: 768px;\n  margin-bottom: 24px;\n}\n\n.overview {\n  font-size: 1.125rem;\n  line-height: 1.6;\n  color: rgba(255, 255, 255, 0.9);\n}\n\n.details {\n  color: rgba(255, 255, 255, 0.6);\n  line-height: 1.8;\n}\n\n.detailItem {\n  margin-bottom: 8px;\n}\n\n.detailLabel {\n  color: rgba(255, 255, 255, 0.8);\n  font-weight: 500;\n}\n\n.loadingContainer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.loadingContent {\n  text-align: center;\n}\n\n.loadingLogo {\n  animation: pulse 2s ease-in-out infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.7; }\n}\n\n.notFoundContainer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.notFoundMessage {\n  color: #ffffff;\n  font-size: 1.25rem;\n}\n\n/* Responsive Design */\n@media (min-width: 768px) {\n  .content {\n    padding: 64px;\n  }\n  \n  .title {\n    font-size: 3rem;\n  }\n  \n  .overview {\n    font-size: 1.25rem;\n  }\n}\n\n@media (min-width: 1024px) {\n  .title {\n    font-size: 4rem;\n  }\n}\n\n@media (max-width: 480px) {\n  .playButton, .listButton, .likeButton {\n    padding: 10px 20px;\n    font-size: 14px;\n  }\n  \n  .title {\n    font-size: 1.75rem;\n  }\n  \n  .overview {\n    font-size: 1rem;\n  }\n}","fullPath":"src/routes/movie/[id]/index.module.css","isBinary":false,"lastModified":1771364966262},"src/routes/watch/[id]/index.module.css":{"name":"index.module.css","type":"file","contents":".container {\n  position: relative;\n  min-height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.main {\n  padding-top: 64px;\n  padding-left: 16px;\n  padding-right: 16px;\n  max-width: 1400px;\n  margin: 0 auto;\n}\n\n.content {\n  padding: 32px 0;\n}\n\n.pageTitle {\n  font-size: 1.5rem;\n  font-weight: 700;\n  text-align: center;\n  margin-bottom: 32px;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  animation: gradient-shift 4s ease infinite;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.videoGrid {\n  display: grid;\n  gap: 24px;\n}\n\n.providersSection {\n  margin-top: 32px;\n}\n\n.alternativeSection {\n  margin-top: 32px;\n}\n\n.sectionTitle {\n  font-size: 1.25rem;\n  font-weight: 600;\n  margin-bottom: 16px;\n  color: rgba(255, 255, 255, 0.9);\n}\n\n.alternativeGrid {\n  display: grid;\n  gap: 16px;\n}\n\n.loadingContainer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.loadingContent {\n  text-align: center;\n}\n\n.loadingLogo {\n  animation: pulse 2s ease-in-out infinite;\n}\n\n@keyframes pulse {\n  0%, 100% { opacity: 1; }\n  50% { opacity: 0.7; }\n}\n\n.notFoundContainer {\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  height: 100vh;\n  background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 50%, #16213e 100%);\n}\n\n.notFoundContent {\n  text-align: center;\n}\n\n.notFoundTitle {\n  color: #ffffff;\n  font-size: 1.25rem;\n  margin-bottom: 16px;\n}\n\n.notFoundMessage {\n  color: rgba(255, 255, 255, 0.6);\n}\n\n/* Responsive Design */\n@media (min-width: 768px) {\n  .main {\n    padding-left: 32px;\n    padding-right: 32px;\n  }\n  \n  .pageTitle {\n    font-size: 2.5rem;\n  }\n  \n  .videoGrid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n  \n  .alternativeGrid {\n    grid-template-columns: repeat(2, 1fr);\n  }\n}\n\n@media (min-width: 1024px) {\n  .content {\n    padding: 40px 0;\n  }\n}","fullPath":"src/routes/watch/[id]/index.module.css","isBinary":false,"lastModified":1771364966262},"src/components/banner/banner.module.css":{"name":"banner.module.css","type":"file","contents":".banner {\n  display: flex;\n  flex-direction: column;\n  padding: 64px 0;\n  min-height: 65vh;\n  justify-content: flex-end;\n  padding-bottom: 48px;\n  position: relative;\n}\n\n.backgroundContainer {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 95vh;\n\n}\n\n.backgroundImage {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  transition: transform 8s ease-in-out;\n}\n\n.backgroundImage:hover {\n  transform: scale(1.05);\n}\n\n.overlay {\n  position: absolute;\n  inset: 0;\n  background: linear-gradient(\n    180deg,\n    transparent 0%,\n    rgba(0, 0, 0, 0.2) 30%,\n    rgba(0, 0, 0, 0.6) 70%,\n    rgba(0, 0, 0, 0.9) 100%\n  );\n}\n\n.content {\n  padding-top: 96px;\n  padding-left: 16px;\n  padding-right: 16px;\n  max-width: 600px;\n  z-index: 10;\n  position: relative;\n}\n\n.title {\n  font-size: 2rem;\n  font-weight: 700;\n  margin-bottom: 16px;\n  text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.8);\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  animation: gradient-shift 4s ease infinite;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.description {\n  font-size: 0.875rem;\n  line-height: 1.6;\n  margin-bottom: 24px;\n  text-shadow: 1px 1px 4px rgba(0, 0, 0, 0.8);\n  color: rgba(255, 255, 255, 0.9);\n  max-width: 500px;\n}\n\n.actions {\n  display: flex;\n  gap: 12px;\n  flex-wrap: wrap;\n}\n\n.playButton {\n  background: linear-gradient(45deg, #ffffff, #f0f0f0);\n  color: #000000;\n  border: none;\n  padding: 12px 24px;\n  border-radius: 8px;\n  font-size: 16px;\n  font-weight: 600;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  text-decoration: none;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  box-shadow: 0 4px 15px rgba(255, 255, 255, 0.2);\n  position: relative;\n  overflow: hidden;\n}\n\n.playButton::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(0, 0, 0, 0.1), transparent);\n  transition: left 0.5s;\n}\n\n.playButton:hover::before {\n  left: 100%;\n}\n\n.playButton:hover {\n  transform: translateY(-2px);\n  box-shadow: 0 8px 25px rgba(255, 255, 255, 0.3);\n  background: linear-gradient(45deg, #f0f0f0, #e0e0e0);\n}\n\n.infoButton {\n  background: rgba(109, 109, 110, 0.7);\n  color: #ffffff;\n  border: 2px solid rgba(255, 255, 255, 0.4);\n  padding: 12px 24px;\n  border-radius: 8px;\n  font-size: 16px;\n  font-weight: 600;\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  text-decoration: none;\n  cursor: pointer;\n  transition: all 0.3s ease;\n  backdrop-filter: blur(10px);\n  position: relative;\n  overflow: hidden;\n}\n\n.infoButton::before {\n  content: '';\n  position: absolute;\n  top: 0;\n  left: -100%;\n  width: 100%;\n  height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.1), transparent);\n  transition: left 0.5s;\n}\n\n.infoButton:hover::before {\n  left: 100%;\n}\n\n.infoButton:hover {\n  background: rgba(109, 109, 110, 0.9);\n  border-color: rgba(255, 255, 255, 0.6);\n  transform: translateY(-2px);\n  box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);\n}\n\n.playIcon, .infoIcon {\n  width: 16px;\n  height: 16px;\n}\n\n/* Responsive Design */\n@media (min-width: 768px) {\n  .content {\n    padding-left: 32px;\n    padding-top: 128px;\n  }\n  \n  .title {\n    font-size: 3rem;\n    margin-bottom: 24px;\n  }\n  \n  .description {\n    font-size: 1rem;\n    max-width: 600px;\n  }\n  \n  .actions {\n    gap: 16px;\n  }\n}\n\n@media (min-width: 1024px) {\n  .content {\n    padding-left: 64px;\n    padding-top: 192px;\n  }\n  \n  .title {\n    font-size: 4rem;\n  }\n  \n  .description {\n    font-size: 1.125rem;\n  }\n}\n\n@media (max-width: 480px) {\n  .playButton, .infoButton {\n    padding: 10px 20px;\n    font-size: 14px;\n  }\n  \n  .title {\n    font-size: 1.75rem;\n  }\n  \n  .description {\n    font-size: 0.8rem;\n  }\n}","fullPath":"src/components/banner/banner.module.css","isBinary":false,"lastModified":1771364966262},"src/components/navbar/navbar.module.css":{"name":"navbar.module.css","type":"file","contents":".navbar {\n  position: fixed;\n  top: 0;\n  left: 0;\n  right: 0;\n  z-index: 1000;\n  transition: all 0.3s ease;\n  backdrop-filter: blur(20px);\n}\n\n.navbar.scrolled {\n  background: rgba(0, 0, 0, 0.95);\n  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);\n}\n\n.navbar.transparent {\n  background: linear-gradient(180deg, rgba(0, 0, 0, 0.8) 0%, transparent 100%);\n}\n\n.container {\n  display: flex;\n  align-items: center;\n  padding: 16px 24px;\n  max-width: 1400px;\n  margin: 0 auto;\n}\n\n.logo {\n  height: 32px;\n  cursor: pointer;\n  transition: transform 0.3s ease;\n}\n\n.logo:hover {\n  transform: scale(1.05);\n}\n\n.nav {\n  display: none;\n  margin-left: 40px;\n}\n\n.navList {\n  display: flex;\n  list-style: none;\n  gap: 32px;\n}\n\n.navLink {\n  color: #ffffff;\n  text-decoration: none;\n  font-size: 16px;\n  font-weight: 400;\n  transition: all 0.3s ease;\n  position: relative;\n}\n\n.navLink::after {\n  content: '';\n  position: absolute;\n  bottom: -4px;\n  left: 0;\n  width: 0;\n  height: 2px;\n  background: linear-gradient(45deg, #e50914, #ff6b6b);\n  transition: width 0.3s ease;\n}\n\n.navLink:hover {\n  color: #e50914;\n}\n\n.navLink:hover::after {\n  width: 100%;\n}\n\n.spacer {\n  flex: 1;\n}\n\n.actions {\n  display: flex;\n  align-items: center;\n  gap: 20px;\n}\n\n.iconButton {\n  background: none;\n  border: none;\n  color: #ffffff;\n  cursor: pointer;\n  padding: 8px;\n  border-radius: 50%;\n  transition: all 0.3s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.iconButton:hover {\n  background: rgba(255, 255, 255, 0.1);\n  color: #e50914;\n  transform: scale(1.1);\n}\n\n.profile {\n  display: flex;\n  align-items: center;\n  gap: 8px;\n  cursor: pointer;\n  padding: 4px 8px;\n  border-radius: 8px;\n  transition: all 0.3s ease;\n}\n\n.profile:hover {\n  background: rgba(255, 255, 255, 0.1);\n}\n\n.profileImage {\n  width: 32px;\n  height: 32px;\n  border-radius: 4px;\n  background: url('/user-icon.png') no-repeat center center;\n  background-size: cover;\n}\n\n\n.profileArrow {\n  width: 16px;\n  height: 16px;\n  transition: transform 0.3s ease;\n}\n\n.profile:hover .profileArrow {\n  transform: rotate(180deg);\n}\n\n/* Mobile Navigation */\n.mobileMenu {\n  display: none;\n  position: absolute;\n  top: 100%;\n  left: 0;\n  right: 0;\n  background: rgba(0, 0, 0, 0.95);\n  backdrop-filter: blur(20px);\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.mobileNavList {\n  list-style: none;\n  padding: 20px;\n}\n\n.mobileNavItem {\n  margin-bottom: 16px;\n}\n\n.mobileNavLink {\n  color: #ffffff;\n  text-decoration: none;\n  font-size: 18px;\n  font-weight: 400;\n  display: block;\n  padding: 12px 0;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n  transition: color 0.3s ease;\n}\n\n.mobileNavLink:hover {\n  color: #e50914;\n}\n\n.hamburger {\n  display: none;\n  flex-direction: column;\n  cursor: pointer;\n  padding: 8px;\n}\n\n.hamburgerLine {\n  width: 24px;\n  height: 2px;\n  background: #ffffff;\n  margin: 2px 0;\n  transition: all 0.3s ease;\n}\n\n/* Responsive Design */\n@media (min-width: 768px) {\n  .nav {\n    display: block;\n  }\n}\n\n@media (max-width: 767px) {\n  .container {\n    padding: 12px 16px;\n  }\n  \n  .logo {\n    height: 28px;\n  }\n  \n  .hamburger {\n    display: flex;\n  }\n  \n  .mobileMenu.open {\n    display: block;\n  }\n  \n  .actions {\n    gap: 12px;\n  }\n}","fullPath":"src/components/navbar/navbar.module.css","isBinary":false,"lastModified":1771364966262},"src/components/router-head/router-head.tsx":{"name":"router-head.tsx","type":"file","contents":"import { component$ } from \"@builder.io/qwik\";\nimport { useDocumentHead, useLocation } from \"@builder.io/qwik-city\";\n\n/**\n * The RouterHead component is placed inside of the document's \u003chead\u003e element.\n */\nexport const RouterHead = component$(() =\u003e {\n  const head = useDocumentHead();\n  const loc = useLocation();\n\n  return (\n    \u003c\u003e\n      \u003ctitle\u003e{head.title}\u003c/title\u003e\n\n      \u003clink rel=\"canonical\" href={loc.url.href} /\u003e\n      \u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" /\u003e\n      \u003clink rel=\"icon\" type=\"image/svg+xml\" href=\"/favicon.svg\" /\u003e\n\n      {head.meta.map((m) =\u003e (\n        \u003cmeta key={m.key} {...m} /\u003e\n      ))}\n\n      {head.links.map((l) =\u003e (\n        \u003clink key={l.key} {...l} /\u003e\n      ))}\n\n      {head.styles.map((s) =\u003e (\n        \u003cstyle key={s.key} {...s} /\u003e\n      ))}\n\n      {head.scripts.map((s) =\u003e (\n        \u003cscript key={s.key} {...s} /\u003e\n      ))}\n    \u003c/\u003e\n  );\n});","fullPath":"src/components/router-head/router-head.tsx","isBinary":false,"lastModified":1771364966262},"src/components/search-input/search-input.tsx":{"name":"search-input.tsx","type":"file","contents":"import { component$, useSignal, $, useVisibleTask$ } from \"@builder.io/qwik\";\nimport { useNavigate, Link } from \"@builder.io/qwik-city\";\nimport type { Movie } from \"~/types\";\nimport styles from \"./search-input.module.css\";\n\nconst API_KEY = import.meta.env.VITE_TMDB_API_KEY;\nconst BASE_URL = \"https://api.themoviedb.org/3\";\n\nexport const SearchInput = component$(() =\u003e {\n  const isOpen = useSignal(false);\n  const query = useSignal(\"\");\n  const suggestions = useSignal\u003cMovie[]\u003e([]);\n  const isLoading = useSignal(false);\n  const showSuggestions = useSignal(false);\n  const nav = useNavigate();\n\n  const searchSuggestions = $(async (searchQuery: string) =\u003e {\n    if (!searchQuery.trim()) {\n      suggestions.value = [];\n      showSuggestions.value = false;\n      return;\n    }\n\n    isLoading.value = true;\n    \n    try {\n      const response = await fetch(\n        `${BASE_URL}/search/multi?api_key=${API_KEY}\u0026language=en-US\u0026query=${encodeURIComponent(searchQuery)}\u0026page=1\u0026include_adult=false`\n      );\n      \n      if (response.ok) {\n        const data = await response.json();\n        const filteredResults = data.results?.filter((item: Movie) =\u003e \n          item.media_type !== 'person' \u0026\u0026 (item.backdrop_path || item.poster_path)\n        ).slice(0, 6) || [];\n        \n        suggestions.value = filteredResults;\n        showSuggestions.value = filteredResults.length \u003e 0;\n      }\n    } catch (error) {\n      console.error(\"Error fetching suggestions:\", error);\n      suggestions.value = [];\n      showSuggestions.value = false;\n    } finally {\n      isLoading.value = false;\n    }\n  });\n\n  const handleInput = $((e: Event) =\u003e {\n    const value = (e.target as HTMLInputElement).value;\n    query.value = value;\n    searchSuggestions(value);\n  });\n\n  const handleSubmit = $((e: Event) =\u003e {\n    e.preventDefault();\n    if (query.value.trim()) {\n      nav(`/search?q=${encodeURIComponent(query.value)}`);\n      closeSuggestions();\n    }\n  });\n\n  const closeSuggestions = $(() =\u003e {\n    showSuggestions.value = false;\n    isOpen.value = false;\n    query.value = \"\";\n    suggestions.value = [];\n  });\n\n  const handleKeyDown = $((e: KeyboardEvent) =\u003e {\n    if (e.key === 'Escape') {\n      closeSuggestions();\n    }\n  });\n\n  const getMediaType = (item: Movie) =\u003e {\n    if (item.media_type === \"tv\" || item.media_type === \"movie\") {\n      return item.media_type;\n    }\n    if (item.name \u0026\u0026 !item.title) return \"tv\";\n    if (item.title \u0026\u0026 !item.name) return \"movie\";\n    return \"movie\";\n  };\n\n  // Close suggestions when clicking outside\n  useVisibleTask$(() =\u003e {\n    const handleClickOutside = (e: Event) =\u003e {\n      const target = e.target as HTMLElement;\n      const searchContainer = document.querySelector('[data-search-container]');\n      if (searchContainer \u0026\u0026 !searchContainer.contains(target)) {\n        showSuggestions.value = false;\n      }\n    };\n\n    document.addEventListener('click', handleClickOutside);\n    return () =\u003e document.removeEventListener('click', handleClickOutside);\n  });\n\n  return (\n    \u003cdiv class={styles.searchContainer} data-search-container\u003e\n      {isOpen.value ? (\n        \u003cdiv class={styles.searchWrapper}\u003e\n          \u003cform onSubmit$={handleSubmit} class={styles.searchForm}\u003e\n            \u003cinput\n              type=\"text\"\n              value={query.value}\n              onInput$={handleInput}\n              onKeyDown$={handleKeyDown}\n              placeholder=\"Titles, people, genres\"\n              class={styles.searchInput}\n              autoFocus\n            /\u003e\n            \u003cbutton\n              type=\"submit\"\n              class={styles.searchSubmitButton}\n              aria-label=\"Search\"\n            \u003e\n              \u003csvg class={styles.searchIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" /\u003e\n              \u003c/svg\u003e\n            \u003c/button\u003e\n            \u003cbutton\n              type=\"button\"\n              onClick$={closeSuggestions}\n              class={styles.closeButton}\n              aria-label=\"Close search\"\n            \u003e\n              \u003csvg class={styles.closeIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M6 18L18 6M6 6l12 12\" /\u003e\n              \u003c/svg\u003e\n            \u003c/button\u003e\n          \u003c/form\u003e\n\n          {/* Suggestions Dropdown */}\n          {(showSuggestions.value || isLoading.value) \u0026\u0026 (\n            \u003cdiv class={styles.suggestionsDropdown}\u003e\n              {isLoading.value ? (\n                \u003cdiv class={styles.loadingItem}\u003e\n                  \u003cdiv class={styles.loadingSpinner}\u003e\u003c/div\u003e\n                  \u003cspan\u003eSearching...\u003c/span\u003e\n                \u003c/div\u003e\n              ) : (\n                \u003c\u003e\n                  {suggestions.value.map((item) =\u003e (\n                    \u003cLink\n                      key={item.id}\n                      href={`/${getMediaType(item)}/${item.id}`}\n                      class={styles.suggestionItem}\n                      onClick$={closeSuggestions}\n                    \u003e\n                      \u003cimg\n                        src={`https://image.tmdb.org/t/p/w92${item.poster_path || item.backdrop_path}`}\n                        alt={item.title || item.name || \"\"}\n                        class={styles.suggestionImage}\n                      /\u003e\n                      \u003cdiv class={styles.suggestionContent}\u003e\n                        \u003ch4 class={styles.suggestionTitle}\u003e\n                          {item.title || item.name}\n                        \u003c/h4\u003e\n                        \u003cp class={styles.suggestionMeta}\u003e\n                          {getMediaType(item) === 'tv' ? 'TV Show' : 'Movie'} • {(item.release_date || item.first_air_date)?.split('-')[0] || 'N/A'}\n                        \u003c/p\u003e\n                      \u003c/div\u003e\n                    \u003c/Link\u003e\n                  ))}\n                  \n                  {query.value.trim() \u0026\u0026 (\n                    \u003cLink\n                      href={`/search?q=${encodeURIComponent(query.value)}`}\n                      class={styles.viewAllItem}\n                      onClick$={closeSuggestions}\n                    \u003e\n                      \u003csvg class={styles.searchIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n                        \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" /\u003e\n                      \u003c/svg\u003e\n                      \u003cspan\u003eView all results for \"{query.value}\"\u003c/span\u003e\n                    \u003c/Link\u003e\n                  )}\n                \u003c/\u003e\n              )}\n            \u003c/div\u003e\n          )}\n        \u003c/div\u003e\n      ) : (\n        \u003cbutton\n          onClick$={() =\u003e (isOpen.value = true)}\n          class={styles.searchButton}\n          aria-label=\"Search\"\n        \u003e\n          \u003csvg class={styles.searchIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n            \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z\" /\u003e\n          \u003c/svg\u003e\n        \u003c/button\u003e\n      )}\n    \u003c/div\u003e\n  );\n});","fullPath":"src/components/search-input/search-input.tsx","isBinary":false,"lastModified":1771364966262},"src/components/video-player/video-player.tsx":{"name":"video-player.tsx","type":"file","contents":"import { component$, useSignal, useVisibleTask$, $ } from \"@builder.io/qwik\";\nimport styles from \"./video-player.module.css\";\n\ninterface VideoPlayerProps {\n  title: string;\n  embedUrl: string;\n  fallbackEmbedUrl?: string;\n  autoPlay?: boolean;\n}\n\nexport const VideoPlayer = component$\u003cVideoPlayerProps\u003e(({ title, embedUrl, fallbackEmbedUrl, autoPlay = true }) =\u003e {\n  const isFullscreen = useSignal(false);\n  const currentUrl = useSignal(embedUrl);\n  const isLoading = useSignal(true);\n  const hasError = useSignal(false);\n\n  const toggleFullscreen = $(() =\u003e {\n    const container = document.querySelector(`[data-video-container=\"${title}\"]`) as HTMLElement;\n    if (!container) return;\n\n    if (!isFullscreen.value) {\n      if (container.requestFullscreen) {\n        container.requestFullscreen();\n      } else if ((container as any).webkitRequestFullscreen) {\n        (container as any).webkitRequestFullscreen();\n      } else if ((container as any).msRequestFullscreen) {\n        (container as any).msRequestFullscreen();\n      }\n      isFullscreen.value = true;\n    } else {\n      if (document.exitFullscreen) {\n        document.exitFullscreen();\n      } else if ((document as any).webkitExitFullscreen) {\n        (document as any).webkitExitFullscreen();\n      } else if ((document as any).msExitFullscreen) {\n        (document as any).msExitFullscreen();\n      }\n      isFullscreen.value = false;\n    }\n  });\n\n  const handleIframeLoad = $(() =\u003e {\n    isLoading.value = false;\n  });\n\n  const handleIframeError = $(() =\u003e {\n    isLoading.value = false;\n    hasError.value = true;\n    if (fallbackEmbedUrl \u0026\u0026 fallbackEmbedUrl !== currentUrl.value) {\n      currentUrl.value = fallbackEmbedUrl;\n      hasError.value = false;\n      isLoading.value = true;\n    }\n  });\n\n  useVisibleTask$(() =\u003e {\n    const handleFullscreenChange = () =\u003e {\n      isFullscreen.value = !!document.fullscreenElement;\n    };\n    document.addEventListener(\"fullscreenchange\", handleFullscreenChange);\n    return () =\u003e {\n      document.removeEventListener(\"fullscreenchange\", handleFullscreenChange);\n    };\n  });\n\n  return (\n    \u003cdiv data-video-container={title} class={styles.videoContainer}\u003e\n      \u003cdiv class={styles.header}\u003e\n        \u003ch2 class={styles.title}\u003e{title}\u003c/h2\u003e\n        \u003cbutton\n          onClick$={toggleFullscreen}\n          class={styles.fullscreenButton}\n          aria-label={isFullscreen.value ? \"Exit fullscreen\" : \"Enter fullscreen\"}\n        \u003e\n          {isFullscreen.value ? (\n            \u003csvg class={styles.fullscreenIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n              \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M9 9V4.5M9 9H4.5M9 9L3.5 3.5m11 5.5V4.5M15 9h4.5M15 9l5.5-5.5M9 15v4.5M9 15H4.5M9 15l-5.5 5.5m11-5.5v4.5m0-4.5h4.5m0 0l-5.5 5.5\" /\u003e\n            \u003c/svg\u003e\n          ) : (\n            \u003csvg class={styles.fullscreenIcon} fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"\u003e\n              \u003cpath stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width={2} d=\"M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4\" /\u003e\n            \u003c/svg\u003e\n          )}\n        \u003c/button\u003e\n      \u003c/div\u003e\n      \u003cdiv class={styles.videoWrapper}\u003e\n        {isLoading.value \u0026\u0026 (\n          \u003cdiv class={styles.loadingContainer}\u003e\n            \u003cdiv class={styles.loadingSpinner}\u003e\u003c/div\u003e\n          \u003c/div\u003e\n        )}\n        {hasError.value \u0026\u0026 !isLoading.value \u0026\u0026 (\n          \u003cdiv class={styles.errorContainer}\u003e\n            \u003cdiv\u003e\n              \u003cp class={styles.errorTitle}\u003eContent Unavailable\u003c/p\u003e\n              \u003cp class={styles.errorMessage}\u003e\n                This media is currently unavailable. Please try again later or check another source.\n              \u003c/p\u003e\n            \u003c/div\u003e\n          \u003c/div\u003e\n        )}\n        \u003ciframe\n          src={`${currentUrl.value}${autoPlay ? \"?autoplay=1\" : \"\"}`}\n          class={styles.iframe}\n          allowFullScreen\n          allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\"\n          title={title}\n          onLoad$={handleIframeLoad}\n          onError$={handleIframeError}\n        \u003e\u003c/iframe\u003e\n      \u003c/div\u003e\n    \u003c/div\u003e\n  );\n});","fullPath":"src/components/video-player/video-player.tsx","isBinary":false,"lastModified":1771364966262},"src/components/search-input/search-input.module.css":{"name":"search-input.module.css","type":"file","contents":".searchContainer {\n  position: relative;\n}\n\n.searchWrapper {\n  position: relative;\n}\n\n.searchForm {\n  display: flex;\n  align-items: center;\n  background: rgba(0, 0, 0, 0.9);\n  border: 2px solid rgba(255, 255, 255, 0.2);\n  border-radius: 8px;\n  overflow: hidden;\n  backdrop-filter: blur(20px);\n  transition: all 0.3s ease;\n  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);\n}\n\n.searchForm:focus-within {\n  border-color: #e50914;\n  box-shadow: 0 0 0 3px rgba(229, 9, 20, 0.2), 0 4px 20px rgba(0, 0, 0, 0.3);\n}\n\n.searchInput {\n  background: transparent;\n  border: none;\n  color: #ffffff;\n  padding: 12px 16px;\n  width: 280px;\n  font-size: 16px;\n  outline: none;\n  flex: 1;\n}\n\n.searchInput::placeholder {\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.searchSubmitButton {\n  background: none;\n  border: none;\n  color: rgba(255, 255, 255, 0.6);\n  cursor: pointer;\n  padding: 12px;\n  transition: color 0.3s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.searchSubmitButton:hover {\n  color: #e50914;\n}\n\n.closeButton {\n  background: none;\n  border: none;\n  color: rgba(255, 255, 255, 0.6);\n  cursor: pointer;\n  padding: 12px;\n  transition: color 0.3s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.closeButton:hover {\n  color: #ffffff;\n}\n\n.searchButton {\n  background: none;\n  border: none;\n  color: rgba(255, 255, 255, 0.8);\n  cursor: pointer;\n  padding: 8px;\n  border-radius: 50%;\n  transition: all 0.3s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.searchButton:hover {\n  color: #e50914;\n  background: rgba(255, 255, 255, 0.1);\n  transform: scale(1.1);\n}\n\n.searchIcon, .closeIcon {\n  width: 20px;\n  height: 20px;\n}\n\n/* Suggestions Dropdown */\n.suggestionsDropdown {\n  position: absolute;\n  top: 100%;\n  left: 0;\n  right: 0;\n  background: rgba(0, 0, 0, 0.95);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  border-top: none;\n  border-radius: 0 0 12px 12px;\n  backdrop-filter: blur(20px);\n  max-height: 400px;\n  overflow-y: auto;\n  z-index: 1000;\n  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);\n}\n\n.loadingItem {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 16px;\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.loadingSpinner {\n  width: 20px;\n  height: 20px;\n  border: 2px solid rgba(255, 255, 255, 0.1);\n  border-left: 2px solid #e50914;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n.suggestionItem {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 12px 16px;\n  text-decoration: none;\n  color: #ffffff;\n  transition: all 0.3s ease;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.suggestionItem:hover {\n  background: rgba(229, 9, 20, 0.1);\n  border-left: 4px solid #e50914;\n  padding-left: 12px;\n}\n\n.suggestionImage {\n  width: 40px;\n  height: 60px;\n  object-fit: cover;\n  border-radius: 4px;\n  flex-shrink: 0;\n}\n\n.suggestionContent {\n  flex: 1;\n  min-width: 0;\n}\n\n.suggestionTitle {\n  font-size: 0.875rem;\n  font-weight: 500;\n  color: #ffffff;\n  margin-bottom: 2px;\n  overflow: hidden;\n  text-overflow: ellipsis;\n  white-space: nowrap;\n}\n\n.suggestionMeta {\n  font-size: 0.75rem;\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.viewAllItem {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 16px;\n  text-decoration: none;\n  color: #e50914;\n  font-weight: 500;\n  transition: all 0.3s ease;\n  border-top: 1px solid rgba(255, 255, 255, 0.1);\n  background: rgba(229, 9, 20, 0.05);\n}\n\n.viewAllItem:hover {\n  background: rgba(229, 9, 20, 0.1);\n  color: #ff6b6b;\n}\n\n/* Custom scrollbar for suggestions */\n.suggestionsDropdown::-webkit-scrollbar {\n  width: 6px;\n}\n\n.suggestionsDropdown::-webkit-scrollbar-track {\n  background: rgba(255, 255, 255, 0.1);\n}\n\n.suggestionsDropdown::-webkit-scrollbar-thumb {\n  background: rgba(229, 9, 20, 0.6);\n  border-radius: 3px;\n}\n\n.suggestionsDropdown::-webkit-scrollbar-thumb:hover {\n  background: rgba(229, 9, 20, 0.8);\n}\n\n/* Responsive Design */\n@media (max-width: 768px) {\n  .searchInput {\n    width: 200px;\n    padding: 10px 12px;\n    font-size: 14px;\n  }\n  \n  .closeButton, .searchSubmitButton {\n    padding: 10px;\n  }\n  \n  .suggestionImage {\n    width: 32px;\n    height: 48px;\n  }\n  \n  .suggestionTitle {\n    font-size: 0.8rem;\n  }\n  \n  .suggestionMeta {\n    font-size: 0.7rem;\n  }\n}\n\n@media (max-width: 480px) {\n  .searchInput {\n    width: 160px;\n  }\n  \n  .suggestionsDropdown {\n    max-height: 300px;\n  }\n}","fullPath":"src/components/search-input/search-input.module.css","isBinary":false,"lastModified":1771364966262},"src/components/video-player/video-player.module.css":{"name":"video-player.module.css","type":"file","contents":".videoContainer {\n  background: linear-gradient(135deg, rgba(17, 17, 17, 0.9), rgba(34, 34, 34, 0.9));\n  border-radius: 12px;\n  overflow: hidden;\n  position: relative;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);\n  transition: all 0.3s ease;\n}\n\n.videoContainer:hover {\n  border-color: rgba(229, 9, 20, 0.3);\n  box-shadow: 0 15px 40px rgba(229, 9, 20, 0.2);\n}\n\n.header {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n  background: linear-gradient(135deg, rgba(34, 34, 34, 0.9), rgba(51, 51, 51, 0.9));\n  padding: 16px 20px;\n  border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.title {\n  font-size: 1.125rem;\n  font-weight: 500;\n  color: #ffffff;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n}\n\n.fullscreenButton {\n  background: none;\n  border: none;\n  color: rgba(255, 255, 255, 0.6);\n  cursor: pointer;\n  padding: 8px;\n  border-radius: 6px;\n  transition: all 0.3s ease;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n.fullscreenButton:hover {\n  color: #e50914;\n  background: rgba(255, 255, 255, 0.1);\n  transform: scale(1.1);\n}\n\n.videoWrapper {\n  position: relative;\n  padding-top: 56.25%; /* 16:9 aspect ratio */\n  background: #000000;\n}\n\n.loadingContainer {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: linear-gradient(135deg, #000000, #1a1a1a);\n}\n\n.loadingSpinner {\n  width: 48px;\n  height: 48px;\n  border: 4px solid rgba(255, 255, 255, 0.1);\n  border-left: 4px solid #e50914;\n  border-radius: 50%;\n  animation: spin 1s linear infinite;\n}\n\n@keyframes spin {\n  0% { transform: rotate(0deg); }\n  100% { transform: rotate(360deg); }\n}\n\n.errorContainer {\n  position: absolute;\n  inset: 0;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  background: linear-gradient(135deg, #000000, #1a1a1a);\n  text-align: center;\n  padding: 20px;\n}\n\n.errorTitle {\n  font-size: 1.25rem;\n  font-weight: 600;\n  color: #e50914;\n  margin-bottom: 8px;\n}\n\n.errorMessage {\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.6);\n  line-height: 1.5;\n}\n\n.iframe {\n  position: absolute;\n  top: 0;\n  left: 0;\n  width: 100%;\n  height: 100%;\n  border: none;\n  background: #000000;\n}\n\n.fullscreenIcon {\n  width: 20px;\n  height: 20px;\n}\n\n/* Responsive Design */\n@media (max-width: 768px) {\n  .header {\n    padding: 12px 16px;\n  }\n  \n  .title {\n    font-size: 1rem;\n  }\n  \n  .fullscreenButton {\n    padding: 6px;\n  }\n  \n  .fullscreenIcon {\n    width: 18px;\n    height: 18px;\n  }\n}","fullPath":"src/components/video-player/video-player.module.css","isBinary":false,"lastModified":1771364966262},"vite.config.ts.timestamp-1755875169138-07e49d4f484b8.mjs":{"name":"vite.config.ts.timestamp-1755875169138-07e49d4f484b8.mjs","type":"file","contents":"// vite.config.ts\nimport { defineConfig } from \"file:///home/project/node_modules/vite/dist/node/index.js\";\nimport { qwikVite } from \"file:///home/project/node_modules/@builder.io/qwik/dist/optimizer.mjs\";\nimport { qwikCity } from \"file:///home/project/node_modules/@builder.io/qwik-city/lib/vite/index.mjs\";\nimport tsconfigPaths from \"file:///home/project/node_modules/vite-tsconfig-paths/dist/index.mjs\";\nvar vite_config_default = defineConfig(() =\u003e {\n  return {\n    plugins: [qwikCity(), qwikVite(), tsconfigPaths()],\n    preview: {\n      headers: {\n        \"Cache-Control\": \"public, max-age=600\"\n      }\n    }\n  };\n});\nexport {\n  vite_config_default as default\n};\n//# sourceMappingURL=data:application/json;base64,\n","fullPath":"vite.config.ts.timestamp-1755875169138-07e49d4f484b8.mjs","isBinary":false,"lastModified":1771364966262},"src/components/streaming-providers/streaming-providers.tsx":{"name":"streaming-providers.tsx","type":"file","contents":"import { component$, useSignal, useTask$ } from \"@builder.io/qwik\";\nimport styles from \"./streaming-providers.module.css\";\n\ninterface Provider {\n  provider_id: number;\n  provider_name: string;\n  logo_path: string;\n}\n\ninterface StreamingProvidersProps {\n  id: string;\n  type: \"movie\" | \"tv\";\n}\n\nexport const StreamingProviders = component$\u003cStreamingProvidersProps\u003e(({ id, type }) =\u003e {\n  const providers = useSignal\u003cProvider[]\u003e([]);\n  const loading = useSignal(true);\n\n  useTask$(async ({ track }) =\u003e {\n    track(() =\u003e id);\n    track(() =\u003e type);\n\n    try {\n      const API_KEY = import.meta.env.VITE_TMDB_API_KEY;\n      const response = await fetch(\n        `https://api.themoviedb.org/3/${type}/${id}/watch/providers?api_key=${API_KEY}`\n      );\n\n      if (!response.ok) {\n        throw new Error(`Failed to fetch providers: ${response.status}`);\n      }\n\n      const data = await response.json();\n\n      if (data.results?.US?.flatrate) {\n        providers.value = data.results.US.flatrate;\n      } else {\n        providers.value = [];\n      }\n    } catch (error) {\n      console.error(\"Error fetching providers:\", error);\n      providers.value = [];\n    } finally {\n      loading.value = false;\n    }\n  });\n\n  if (loading.value) {\n    return (\n      \u003cdiv class={styles.container}\u003e\n        \u003ch2 class={styles.title}\u003eLoading streaming providers...\u003c/h2\u003e\n      \u003c/div\u003e\n    );\n  }\n\n  if (providers.value.length === 0) {\n    return (\n      \u003cdiv class={styles.container}\u003e\n        \u003ch2 class={styles.title}\u003eStreaming Providers\u003c/h2\u003e\n        \u003cp class={styles.noProvidersMessage}\u003eNo streaming information available for this title.\u003c/p\u003e\n      \u003c/div\u003e\n    );\n  }\n\n  return (\n    \u003cdiv class={styles.container}\u003e\n      \u003ch2 class={styles.title}\u003eAvailable on Streaming\u003c/h2\u003e\n      \u003cdiv class={styles.grid}\u003e\n        {providers.value.map((provider) =\u003e (\n          \u003cdiv key={provider.provider_id} class={styles.providerItem}\u003e\n            \u003cdiv class={styles.logoContainer}\u003e\n              \u003cimg\n                src={`https://image.tmdb.org/t/p/original${provider.logo_path}`}\n                alt={provider.provider_name}\n                class={styles.logo}\n              /\u003e\n            \u003c/div\u003e\n            \u003cp class={styles.providerName}\u003e{provider.provider_name}\u003c/p\u003e\n          \u003c/div\u003e\n        ))}\n      \u003c/div\u003e\n    \u003c/div\u003e\n  );\n});","fullPath":"src/components/streaming-providers/streaming-providers.tsx","isBinary":false,"lastModified":1771364966262},"src/components/streaming-providers/streaming-providers.module.css":{"name":"streaming-providers.module.css","type":"file","contents":".container {\n  background: linear-gradient(135deg, rgba(17, 17, 17, 0.9), rgba(34, 34, 34, 0.9));\n  border-radius: 12px;\n  padding: 24px;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);\n  transition: all 0.3s ease;\n}\n\n.container:hover {\n  border-color: rgba(229, 9, 20, 0.3);\n  box-shadow: 0 15px 40px rgba(229, 9, 20, 0.2);\n}\n\n.title {\n  font-size: 1.25rem;\n  font-weight: 600;\n  text-align: center;\n  margin-bottom: 24px;\n  background: linear-gradient(45deg, #ffffff, #e50914);\n  background-size: 200% 200%;\n  -webkit-background-clip: text;\n  -webkit-text-fill-color: transparent;\n  background-clip: text;\n  animation: gradient-shift 4s ease infinite;\n}\n\n@keyframes gradient-shift {\n  0%, 100% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n.grid {\n  display: grid;\n  grid-template-columns: repeat(2, 1fr);\n  gap: 24px;\n  justify-items: center;\n}\n\n.providerItem {\n  text-align: center;\n  transition: transform 0.3s ease;\n}\n\n.providerItem:hover {\n  transform: translateY(-4px);\n}\n\n.logoContainer {\n  position: relative;\n  width: 64px;\n  height: 64px;\n  margin: 0 auto 8px;\n  transition: transform 0.3s ease;\n  border-radius: 12px;\n  overflow: hidden;\n  box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);\n}\n\n.logoContainer:hover {\n  transform: scale(1.1);\n  box-shadow: 0 8px 25px rgba(229, 9, 20, 0.4);\n}\n\n.logo {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n  border-radius: 12px;\n}\n\n.providerName {\n  font-size: 0.875rem;\n  color: rgba(255, 255, 255, 0.8);\n  font-weight: 500;\n}\n\n.loadingMessage {\n  text-align: center;\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.noProvidersMessage {\n  text-align: center;\n  color: rgba(255, 255, 255, 0.6);\n  line-height: 1.6;\n}\n\n/* Responsive Design */\n@media (min-width: 480px) {\n  .grid {\n    grid-template-columns: repeat(3, 1fr);\n  }\n}\n\n@media (min-width: 768px) {\n  .grid {\n    grid-template-columns: repeat(4, 1fr);\n  }\n}\n\n@media (min-width: 1024px) {\n  .grid {\n    grid-template-columns: repeat(6, 1fr);\n  }\n}\n\n@media (max-width: 480px) {\n  .container {\n    padding: 20px;\n  }\n  \n  .logoContainer {\n    width: 56px;\n    height: 56px;\n  }\n  \n  .providerName {\n    font-size: 0.8rem;\n  }\n}","fullPath":"src/components/streaming-providers/streaming-providers.module.css","isBinary":false,"lastModified":1771364966262}},"brokenAssets":[],"canAdministrate":true,"canChangeVisibility":true,"canFork":true,"canForkToPersonal":true,"canHostWithoutBadge":false,"canMakePrivate":true,"canManage":true,"canTransfer":true,"canUpdateSettings":true,"canUploadFiles":true,"canUseCorsProxy":false,"canUseLocalhostAccess":false,"canUsePaidFeatures":false,"canView":true,"commercial":false,"currentUserIsOwner":true,"dependencies":{"jpack":{"appDependencies":{},"resDependencies":{}},"externalDeps":[],"externalResources":[]},"description":"Run Lotsoflex created by L Fakh on StackBlitz","editedAt":"2026-02-17T21:57:58.003Z","forkTargets":[{"action":"fork","default":true,"target":{"avatar":"https://avatars.githubusercontent.com/u/154886003","kind":"USER","name":"mrabetfakhri3","provider":null,"slug":"mrabetfakhri3"}}],"forks":0,"framework":{"logoDarkUrl":"https://c.staticblitz.com/assets/frameworks/qwik-433d2d36cbe12b3e34116d98dae7fd2ce0c95e2bf5328e1cca10afd3fa2f2501.svg","logoUrl":"https://c.staticblitz.com/assets/frameworks/qwik-433d2d36cbe12b3e34116d98dae7fd2ce0c95e2bf5328e1cca10afd3fa2f2501.svg","slug":"qwik"},"frozen":null,"guestId":null,"hasBrokenAssets":false,"id":63834047,"invitees":[],"lastEditor":{"id":3605966,"username":"mrabetfakhri3"},"localhostAccessEnabled":false,"organization":null,"organizationMemberRole":null,"owner":{"avatar":"https://avatars.githubusercontent.com/u/154886003","email":"mrabetfakhri3@gmail.com","id":3605966,"name":"mrabetfakhri3@gmail.com","username":"mrabetfakhri3"},"preset":"node","settings":{"defaultProjectRole":"no-access","compile":{"action":"hmr","trigger":"auto","clearConsole":true}},"slug":"github-myj2gp7w-78dbajhd","title":"Lfakh - Lotsoflex (duplicated)","userIsParticipant":false,"views":0,"visibility":"private","webcontainerBased":true,"editorLivePresence":false}}</script>
